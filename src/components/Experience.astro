---
const experience = [
  {
    role: 'Web Developer Intern',
    company: 'City Government of Biñan',
    period: 'Apr 2026 – Present',
    tags: ['CodeIgniter 4', 'PHP 8.2+', 'MySQL', 'Bootstrap 5'],
    bullets: [
      'Developing the CEDO Financial Assistance Program — a voucher management system (featured in Projects) with role-based access, bulk Excel import/export, and audit logging.',
      'Built the Biñan Access Card ID/access-card system with an asynchronous background worker for batch import/export.',
      'Designed database schemas and generated large-scale seed data for student and school records.',
    ],
  },
];
---
<section id="experience" class="experience-section reveal screen">
  <p class="eyebrow">Where I've worked</p>
  <h2>Experience</h2>
  {experience.map((e) => (
    <article class="card exp-card">
      <div class="exp-head">
        <div>
          <h3>{e.role}</h3>
          <p class="exp-org">{e.company}</p>
        </div>
        <span class="exp-period">{e.period}</span>
      </div>
      <ul class="exp-bullets">
        {e.bullets.map((b) => <li>{b}</li>)}
      </ul>
      <ul class="tags">
        {e.tags.map((t) => <li>{t}</li>)}
      </ul>
    </article>
  ))}
</section>

<style is:global>
  .exp-card { border-left: 3px solid var(--accent); padding: 2rem; }
  .exp-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .exp-card h3 { font-size: 1.3rem; color: var(--text); }
  .exp-org { color: var(--accent); font-weight: 600; margin-top: 0.15rem; }
  .exp-period { font-family: var(--font-mono); font-size: 0.8rem; color: var(--muted); white-space: nowrap; padding-top: 0.35rem; }
  .exp-bullets { margin: 0 0 1.25rem 1.1rem; color: var(--muted); line-height: 1.65; display: flex; flex-direction: column; gap: 0.5rem; }
  .exp-card .tags { margin-bottom: 0; }
</style>
