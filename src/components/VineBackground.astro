---
---
<canvas id="bg-canvas" aria-hidden="true"></canvas>

<style is:global>
  #bg-canvas {
    position: fixed; inset: 0; width: 100%; height: 100%;
    z-index: -1; pointer-events: none;
  }
</style>

<script>
  const canvas = document.getElementById('bg-canvas');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && canvas.getContext) {
    const ctx = canvas.getContext('2d');
    let w = 0, h = 0;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    const css = (n, f) => getComputedStyle(document.documentElement).getPropertyValue(n).trim() || f;
    const hexToRgb = (hex) => {
      const m = hex.replace('#', '');
      const n = parseInt(m.length === 3 ? m.split('').map((c) => c + c).join('') : m, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };
    let ACCENT = hexToRgb(css('--accent', '#6366f1'));
    let MUTED = hexToRgb(css('--muted', '#8b949e'));
    const acc = (a) => `rgba(${ACCENT[0]},${ACCENT[1]},${ACCENT[2]},${a})`;
    const mut = (a) => `rgba(${MUTED[0]},${MUTED[1]},${MUTED[2]},${a})`;

    const GRID = 42;          // dot-grid spacing
    const LINK = 130;         // particle link distance
    const MOUSE_R = 160;      // mouse influence radius
    let particles = [];
    const mouse = { x: -9999, y: -9999 };

    const initParticles = () => {
      const count = Math.min(90, Math.round((w * h) / 22000));
      particles = Array.from({ length: count }, () => ({
        x: Math.random() * w, y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.35, vy: (Math.random() - 0.5) * 0.35,
      }));
    };

    const resize = () => {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      initParticles();
    };
    window.addEventListener('resize', resize);
    window.addEventListener('pointermove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
    window.addEventListener('pointerleave', () => { mouse.x = -9999; mouse.y = -9999; });
    window.addEventListener('theme-change', () => {
      ACCENT = hexToRgb(css('--accent', '#6366f1'));
      MUTED = hexToRgb(css('--muted', '#8b949e'));
    });
    resize();

    const drawGrid = () => {
      for (let x = GRID; x < w; x += GRID) {
        for (let y = GRID; y < h; y += GRID) {
          const dx = x - mouse.x, dy = y - mouse.y;
          const d = Math.hypot(dx, dy);
          if (d < MOUSE_R) {
            const t = 1 - d / MOUSE_R;
            ctx.beginPath();
            ctx.arc(x, y, 1 + t * 1.6, 0, Math.PI * 2);
            ctx.fillStyle = acc(0.15 + t * 0.5);
            ctx.fill();
          } else {
            ctx.beginPath();
            ctx.arc(x, y, 1, 0, Math.PI * 2);
            ctx.fillStyle = mut(0.12);
            ctx.fill();
          }
        }
      }
    };

    const step = () => {
      for (const p of particles) {
        // mouse repel
        const dx = p.x - mouse.x, dy = p.y - mouse.y;
        const d = Math.hypot(dx, dy);
        if (d < MOUSE_R && d > 0.01) {
          const f = (1 - d / MOUSE_R) * 0.6;
          p.vx += (dx / d) * f;
          p.vy += (dy / d) * f;
        }
        p.vx *= 0.98; p.vy *= 0.98;
        // gentle floor speed so they keep drifting
        p.x += p.vx || (p.vx = (Math.random() - 0.5) * 0.3);
        p.y += p.vy;
        // wrap
        if (p.x < -10) p.x = w + 10; if (p.x > w + 10) p.x = -10;
        if (p.y < -10) p.y = h + 10; if (p.y > h + 10) p.y = -10;
      }
    };

    const drawParticles = () => {
      // links between nearby particles
      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j];
          const dx = a.x - b.x, dy = a.y - b.y;
          const d = Math.hypot(dx, dy);
          if (d < LINK) {
            ctx.beginPath();
            ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = acc(0.14 * (1 - d / LINK));
            ctx.lineWidth = 1;
            ctx.stroke();
          }
        }
        // link to mouse
        const mdx = a.x - mouse.x, mdy = a.y - mouse.y;
        const md = Math.hypot(mdx, mdy);
        if (md < MOUSE_R) {
          ctx.beginPath();
          ctx.moveTo(a.x, a.y); ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = acc(0.2 * (1 - md / MOUSE_R));
          ctx.stroke();
        }
        // dot
        ctx.beginPath();
        ctx.arc(a.x, a.y, 1.6, 0, Math.PI * 2);
        ctx.fillStyle = acc(0.5);
        ctx.fill();
      }
    };

    let running = true;
    const frame = () => {
      if (!running) return;
      ctx.clearRect(0, 0, w, h);
      drawGrid();
      step();
      drawParticles();
      requestAnimationFrame(frame);
    };

    if (reduce) {
      ctx.clearRect(0, 0, w, h);
      drawGrid();
      drawParticles();
    } else {
      document.addEventListener('visibilitychange', () => {
        const was = running;
        running = !document.hidden;
        if (running && !was) frame();
      });
      frame();
    }
  }
</script>
