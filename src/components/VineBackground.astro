---
---
<canvas id="bg-canvas" aria-hidden="true"></canvas>

<style is:global>
  #bg-canvas { position: fixed; inset: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
</style>

<script>
  function boot(canvas) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const ctx = canvas.getContext('2d');
    let w = 0, h = 0;
    // Delta-time factor (1 = 60fps). Scales per-frame motion so speed is the
    // same on 60Hz and 144Hz displays. Clamped to avoid jumps after stalls.
    let DT = 1, lastT = performance.now();
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const TAU = Math.PI * 2;
    const rand = (a, b) => a + Math.random() * (b - a);

    const css = (n, f) => getComputedStyle(document.documentElement).getPropertyValue(n).trim() || f;
    const hexToRgb = (hex) => {
      const m = hex.replace('#', '');
      const n = parseInt(m.length === 3 ? m.split('').map((c) => c + c).join('') : m, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };
    let ACCENT = [99, 102, 241], MUTED = [139, 148, 158], BG = [13, 17, 23];
    const readColors = () => {
      ACCENT = hexToRgb(css('--accent', '#6366f1'));
      MUTED = hexToRgb(css('--muted', '#8b949e'));
      BG = hexToRgb(css('--bg', '#0d1117'));
    };
    const rgba = (c, a) => `rgba(${c[0]},${c[1]},${c[2]},${a})`;

    const mouse = { x: -9999, y: -9999 };
    const onMove = (e) => { mouse.x = e.clientX; mouse.y = e.clientY; };
    const onLeave = () => { mouse.x = -9999; mouse.y = -9999; };
    window.addEventListener('pointermove', onMove);
    window.addEventListener('pointerleave', onLeave);

    /* ---------- Effect A: constellation + aurora + shooting stars + crystal garden (dark) ---------- */
    const LINK = 130;
    const CRYSTAL = [[99, 102, 241], [34, 211, 238], [167, 139, 250], [45, 212, 191], [236, 72, 153]];
    let particles = [], aurora = [], darkStems = [], darkHidden = false;

    const makeCrystal = (x) => {
      const len = rand(50, 140);
      return { x, len, chars: fillChars(len), grown: 0, growSpeed: rand(0.12, 0.3), seed: rand(0, TAU), sway: rand(3, 8), color: CRYSTAL[Math.floor(Math.random() * CRYSTAL.length)] };
    };
    const conInit = () => {
      const count = Math.min(90, Math.round((w * h) / 22000));
      particles = Array.from({ length: count }, () => ({ x: Math.random() * w, y: Math.random() * h, vx: rand(-0.3, 0.3), vy: rand(-0.3, 0.3) }));
      aurora = Array.from({ length: 3 }, () => ({ x: rand(0, w), y: rand(0, h * 0.7), r: rand(200, 380), c: CRYSTAL[Math.floor(Math.random() * CRYSTAL.length)], vx: rand(-0.12, 0.12), vy: rand(-0.08, 0.08) }));
      darkStems = []; darkHidden = false;
      for (let x = 50; x < w; x += rand(70, 130)) darkStems.push(makeCrystal(x + rand(-20, 20)));
    };
    const drawCrystalBloom = (x, y, color, alpha) => {
      const art = [' /\\ ', '<><>', ' \\/ '];
      ctx.save(); ctx.shadowColor = rgba(color, 0.9 * alpha); ctx.shadowBlur = 8;
      ctx.font = 'bold 13px ui-monospace, monospace';
      for (let r = 0; r < art.length; r++) { const row = art[r]; for (let c = 0; c < row.length; c++) { const ch = row[c]; if (ch === ' ') continue; ctx.fillStyle = rgba(color, alpha); ctx.fillText(ch, x + (c - row.length / 2) * 7, y + (r - art.length + 0.5) * 11); } }
      ctx.restore(); ctx.font = '13px ui-monospace, monospace';
    };
    const conFrame = () => {
      ctx.clearRect(0, 0, w, h);
      const t = performance.now() * 0.001;

      // aurora haze
      ctx.globalCompositeOperation = 'lighter';
      for (const a of aurora) {
        a.x += a.vx * DT; a.y += a.vy * DT;
        if (a.x < -a.r) a.x = w + a.r; if (a.x > w + a.r) a.x = -a.r;
        if (a.y < -a.r) a.y = h + a.r; if (a.y > h + a.r) a.y = -a.r;
        const g = ctx.createRadialGradient(a.x, a.y, 0, a.x, a.y, a.r);
        g.addColorStop(0, rgba(a.c, 0.06)); g.addColorStop(1, rgba(a.c, 0));
        ctx.fillStyle = g; ctx.beginPath(); ctx.arc(a.x, a.y, a.r, 0, TAU); ctx.fill();
      }
      ctx.globalCompositeOperation = 'source-over';

      // constellation
      for (const p of particles) {
        p.x += p.vx * DT; p.y += p.vy * DT;
        if (p.x < -10) p.x = w + 10; if (p.x > w + 10) p.x = -10;
        if (p.y < -10) p.y = h + 10; if (p.y > h + 10) p.y = -10;
      }
      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j], d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < LINK) { ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.strokeStyle = rgba(ACCENT, 0.14 * (1 - d / LINK)); ctx.lineWidth = 1; ctx.stroke(); }
        }
        ctx.beginPath(); ctx.arc(a.x, a.y, 1.6, 0, TAU); ctx.fillStyle = rgba(ACCENT, 0.5); ctx.fill();
      }

      // bioluminescent bottom garden (grows near footer, wilts on scroll away)
      const docH = document.documentElement.scrollHeight;
      const bf = Math.max(0, 1 - (docH - (window.scrollY + h)) / (h * 0.85));
      if (bf > 0) {
        if (darkHidden) darkHidden = false;
        const fr = document.querySelector('.footer');
        const baseY = fr ? fr.getBoundingClientRect().top : h;
        ctx.font = '13px ui-monospace, monospace';
        for (const b of darkStems) {
          if (b.grown < b.len) b.grown += b.growSpeed * DT;
          for (const c of b.chars) {
            if (c.d > b.grown) break;
            const x = b.x + Math.sin(t * 0.6 + b.seed) * b.sway * (c.d / b.len);
            const y = baseY - 4 - c.d;
            if (Math.random() < 0.01) c.ch = randChar();
            ctx.fillStyle = rgba(b.color, (0.3 + 0.4 * (1 - c.d / b.len)) * bf);
            ctx.fillText(c.ch, x, y);
          }
          if (b.grown >= b.len) drawCrystalBloom(b.x + Math.sin(t * 0.6 + b.seed) * b.sway, baseY - 4 - b.len, b.color, bf);
        }
      } else if (!darkHidden) {
        darkHidden = true;
        darkStems.forEach((b) => Object.assign(b, makeCrystal(b.x)));
      }
    };

    /* ---------- Effect B: hanging vine garland + flowers + fairy lights (light) ---------- */
    const STEM = [54, 110, 68], LEAF = [86, 148, 96], GLOW = [255, 214, 130];
    const FLOWERS = [[231, 84, 128], [239, 68, 68], [245, 158, 11], [168, 85, 247], [236, 72, 153], [250, 204, 21], [59, 130, 246]];
    let strands = [], lights = [], bottomStems = [], bees = [], birds = [];
    let gardenHidden = false, bottomHidden = false;
    const t0 = performance.now();

    const CHARSET = '01{}[]()<>/\\;:*#+=$%&|!?~^'.split('');
    const STEPY = 16; // vertical char spacing
    let falling = [];
    const randChar = () => CHARSET[Math.floor(Math.random() * CHARSET.length)];
    const fillChars = (len) => {
      const chars = [];
      let i = 0;
      for (let d = STEPY; d < len; d += STEPY) { chars.push({ d, ch: randChar(), leaf: i % 2 === 1 ? (Math.floor(i / 2) % 2 === 0 ? 1 : -1) : 0 }); i++; }
      return chars;
    };
    const makeStrand = (x) => {
      const len = rand(150, 380);
      return {
        x, len, seed: rand(0, TAU), curl: rand(8, 20), curlF: rand(0.012, 0.022), sway: rand(10, 22),
        chars: fillChars(len),
        tip: Math.random() < 0.7 ? FLOWERS[Math.floor(Math.random() * FLOWERS.length)] : null,
        grown: 0, growSpeed: rand(0.3, 0.7), state: 'grow', alpha: 1, hold: 0, delay: rand(0, 200),
      };
    };
    const resetStrand = (s) => {
      s.len = rand(150, 380); s.chars = fillChars(s.len); s.seed = rand(0, TAU);
      s.tip = Math.random() < 0.7 ? FLOWERS[Math.floor(Math.random() * FLOWERS.length)] : null;
      s.grown = 0; s.growSpeed = rand(0.3, 0.7); s.state = 'grow'; s.alpha = 1; s.hold = 0; s.delay = rand(30, 180); s.visiting = false;
    };
    const gardenInit = () => {
      strands = []; lights = []; falling = []; bottomStems = []; bees = []; birds = [];
      const gap = 190;
      for (let x = gap / 2; x <= w; x += gap) strands.push(makeStrand(x + rand(-30, 30)));
      for (let k = 0; k < 2; k++) { strands.push(makeStrand(rand(20, 160))); strands.push(makeStrand(w - rand(20, 160))); }
      for (let x = 40; x < w; x += rand(60, 100)) lights.push({ x, phase: rand(0, TAU), ch: randChar() });
      for (let x = 50; x < w; x += rand(70, 130)) bottomStems.push(makeBottomStem(x + rand(-20, 20)));
    };
    const strandX = (s, d, t) => s.x + Math.sin(d * s.curlF + s.seed) * s.curl + Math.sin(t * 0.6 + s.seed) * s.sway * (d / s.len);

    // Big ASCII flower (rendered as a small glyph grid)
    const FLOWER_ART = [' @ ', '@O@', ' @ '];
    const drawFlowerAscii = (cx, cy, color, alpha) => {
      if (alpha <= 0) return;
      const cw = 6, chh = 9;
      ctx.font = 'bold 11px ui-monospace, monospace';
      for (let r = 0; r < FLOWER_ART.length; r++) {
        const row = FLOWER_ART[r];
        for (let c = 0; c < row.length; c++) {
          const ch = row[c];
          if (ch === ' ') continue;
          ctx.fillStyle = ch === 'O' ? rgba([250, 204, 21], alpha) : rgba(color, alpha);
          ctx.fillText(ch, cx + (c - row.length / 2) * cw, cy + (r - FLOWER_ART.length / 2) * chh);
        }
      }
      ctx.font = '13px ui-monospace, monospace';
    };

    // Bottom garden — sunflowers, roses, tulips as ASCII art, growing up from the base.
    const BLOOMS = [
      { art: ['\\|/', '-O-', '/|\\'], color: [250, 204, 21] }, // sunflower
      { art: ['(@)', '@@@', ' | '], color: [231, 84, 128] },   // rose pink
      { art: ['(@)', '@@@', ' | '], color: [239, 68, 68] },    // rose red
      { art: ['\\_/', ' | '], color: [168, 85, 247] },         // tulip purple
      { art: ['\\_/', ' | '], color: [236, 72, 153] },         // tulip magenta
      { art: ['\\_/', ' | '], color: [59, 130, 246] },         // tulip blue
      { art: ['\\_/', ' | '], color: [245, 158, 11] },         // tulip orange
    ];
    const drawArt = (cx, cy, art, color, alpha) => {
      if (alpha <= 0) return;
      const cw = 7, chh = 12;
      ctx.font = 'bold 13px ui-monospace, monospace';
      for (let r = 0; r < art.length; r++) {
        const row = art[r];
        for (let c = 0; c < row.length; c++) {
          const ch = row[c];
          if (ch === ' ') continue;
          ctx.fillStyle = ch === 'O' ? rgba([120, 72, 20], alpha) : rgba(color, alpha);
          ctx.fillText(ch, cx + (c - row.length / 2) * cw, cy + (r - art.length + 0.5) * chh);
        }
      }
      ctx.font = '13px ui-monospace, monospace';
    };
    // ASCII bee that flies toward the garden blooms
    const drawBee = (x, y, dir, alpha) => {
      ctx.font = 'bold 12px ui-monospace, monospace';
      ctx.fillStyle = rgba([200, 200, 210], 0.8 * alpha);
      ctx.fillText('\\ /', x, y - 8);
      ctx.fillStyle = rgba([245, 190, 20], alpha);
      ctx.fillText(dir >= 0 ? '>≡·' : '·≡<', x, y);
      ctx.font = '13px ui-monospace, monospace';
    };
    // ASCII bird that flies to a garland flower and perches; wings flap via wob.
    const drawBird = (x, y, wob, dir, alpha) => {
      ctx.font = 'bold 13px ui-monospace, monospace';
      ctx.fillStyle = rgba([88, 72, 58], alpha);
      const up = Math.sin(wob) > 0;
      ctx.fillText(up ? (dir >= 0 ? '\\o>' : '<o/') : (dir >= 0 ? '/o>' : '<o\\'), x, y);
      ctx.font = '13px ui-monospace, monospace';
    };
    const makeBottomStem = (x) => {
      const len = rand(60, 150);
      return { x, len, chars: fillChars(len), grown: 0, growSpeed: rand(0.12, 0.28), seed: rand(0, TAU), sway: rand(4, 10), type: BLOOMS[Math.floor(Math.random() * BLOOMS.length)] };
    };

    const gardenFrame = () => {
      ctx.clearRect(0, 0, w, h);
      const t = (performance.now() - t0) * 0.001;
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';

      // fades: top garland near the hero, bottom garden near the page end
      const sf = Math.max(0, 1 - window.scrollY / (h * 0.85));
      const docH = document.documentElement.scrollHeight;
      const bf = Math.max(0, 1 - (docH - (window.scrollY + h)) / (h * 0.85));

      if (sf <= 0) { gardenHidden = true; falling.length = 0; birds.length = 0; }
      else {
      // returning to the top: regrow everything from the start (staggered)
      if (gardenHidden) {
        gardenHidden = false;
        falling.length = 0;
        strands.forEach((s, i) => { resetStrand(s); s.delay = i * 6 + rand(0, 40); });
      }

      // top wire
      ctx.beginPath(); ctx.moveTo(0, 8);
      for (let x = 0; x <= w; x += 20) ctx.lineTo(x, 8 + Math.sin(x * 0.01) * 6);
      ctx.strokeStyle = rgba(STEM, 0.35 * sf); ctx.lineWidth = 1; ctx.stroke();

      // fairy-light glyphs
      ctx.font = '13px ui-monospace, monospace';
      for (const L of lights) {
        const y = 8 + Math.sin(L.x * 0.01) * 6;
        const tw = 0.5 + 0.5 * Math.sin(t * 2 + L.phase);
        ctx.fillStyle = rgba(GLOW, (0.35 + 0.6 * tw) * sf);
        ctx.fillText(L.ch, L.x, y);
      }

      // strands lifecycle: grow -> hold -> flower drops -> fade -> regrow
      ctx.font = '13px ui-monospace, monospace';
      for (const s of strands) {
        if (s.delay > 0) { s.delay -= DT; continue; }

        if (s.state === 'grow') {
          s.grown += s.growSpeed * DT;
          if (s.grown >= s.len) { s.grown = s.len; s.state = 'hold'; s.hold = 120; }
        } else if (s.state === 'hold') {
          // Flowering vines wait for a bird to perch (see bird logic below).
          // Plain vines drop on their own timer.
          if (!s.tip) {
            s.hold -= DT;
            if (s.hold <= 0) s.state = 'fade';
          }
        } else if (s.state === 'fade') {
          s.alpha -= 0.008 * DT;
          if (s.alpha <= 0) resetStrand(s);
        }

        for (const c of s.chars) {
          if (c.d > s.grown) break;
          const x = strandX(s, c.d, t);
          const y = 8 + c.d;
          if (Math.random() < 0.01) c.ch = randChar();
          const depthFade = 0.35 + 0.5 * (1 - c.d / s.len);
          ctx.fillStyle = rgba(STEM, depthFade * s.alpha * sf);
          ctx.fillText(c.ch, x, y);
          if (c.leaf) {
            ctx.font = 'bold 17px ui-monospace, monospace';
            ctx.fillStyle = rgba(LEAF, Math.min(1, depthFade * 1.7) * s.alpha * sf);
            ctx.fillText(c.leaf < 0 ? '❰' : '❱', x + c.leaf * 12, y);
            ctx.font = '13px ui-monospace, monospace';
          }
        }
        // big ascii bloom while fully grown & holding (before it drops)
        if (s.tip && s.state === 'hold') {
          drawFlowerAscii(strandX(s, s.len, t), 8 + s.len + STEPY, s.tip, 0.95 * s.alpha * sf);
        }
      }

      // a bird flies to a flowering strand, perches, then the flower drops & the vine wilts
      const perchable = strands.filter((s) => s.tip && s.state === 'hold' && s.delay <= 0 && s.grown >= s.len && !s.visiting);
      if (birds.length < 1 && Math.random() < 0.012 * DT && perchable.length) {
        const s = perchable[Math.floor(Math.random() * perchable.length)];
        s.visiting = true;
        birds.push({ target: s, x: Math.random() < 0.5 ? -30 : w + 30, y: rand(24, 90), hover: 0, leaving: false, wob: rand(0, TAU), lx: 0, ly: 0 });
      }
      birds = birds.filter((b) => {
        b.wob += 0.18 * DT;
        if (!b.leaving) {
          const s = b.target;
          const fx = strandX(s, s.len, t) + 8, fy = 8 + s.len - 6; // just beside the bloom
          const dx = fx - b.x, dy = fy - b.y, dist = Math.hypot(dx, dy);
          b.x += dx * 0.02 * DT; b.y += dy * 0.02 * DT;
          drawBird(b.x, b.y, b.wob, dx >= 0 ? 1 : -1, sf);
          if (dist < 14) {
            b.hover += DT;
            if (b.hover > 90) {
              if (s.tip) falling.push({ x: strandX(s, s.len, t), y: 8 + s.len, vy: rand(0.25, 0.6), alpha: 1, color: s.tip, wob: rand(0, TAU) });
              s.state = 'fade'; s.visiting = false;
              b.leaving = true; b.lx = b.x < w / 2 ? -60 : w + 60; b.ly = rand(20, 80);
            }
          }
        } else {
          const dx = b.lx - b.x, dy = b.ly - b.y;
          b.x += dx * 0.03 * DT; b.y += dy * 0.03 * DT;
          drawBird(b.x, b.y, b.wob, dx >= 0 ? 1 : -1, sf);
        }
        return !(b.leaving && (b.x < -50 || b.x > w + 50));
      });

      // falling ascii flowers
      falling = falling.filter((f) => {
        f.vy += 0.008 * DT; f.y += f.vy * DT; f.wob += 0.05 * DT; f.x += Math.sin(f.wob) * 0.6 * DT; f.alpha -= 0.004 * DT;
        if (f.alpha <= 0 || f.y > h + 30) return false;
        drawFlowerAscii(f.x, f.y, f.color, Math.max(0, f.alpha) * sf);
        return true;
      });
      } // end top garland

      // bottom garden — grows only while visible (bf>0); paused + persistent otherwise
      if (bf > 0) {
        if (bottomHidden) bottomHidden = false;
        const fr = document.querySelector('.footer');
        const baseY = fr ? fr.getBoundingClientRect().top : h;
        ctx.font = '13px ui-monospace, monospace';
        for (const b of bottomStems) {
          if (b.grown < b.len) b.grown += b.growSpeed * DT;
          for (const c of b.chars) {
            if (c.d > b.grown) break;
            const swayX = Math.sin(t * 0.6 + b.seed) * b.sway * (c.d / b.len);
            const x = b.x + swayX;
            const y = baseY - 4 - c.d;
            if (Math.random() < 0.01) c.ch = randChar();
            const df = (0.35 + 0.45 * (1 - c.d / b.len)) * bf;
            ctx.fillStyle = rgba(STEM, df);
            ctx.fillText(c.ch, x, y);
            if (c.leaf) {
              ctx.font = 'bold 17px ui-monospace, monospace';
              ctx.fillStyle = rgba(LEAF, Math.min(1, df * 1.7));
              ctx.fillText(c.leaf < 0 ? '❰' : '❱', x + c.leaf * 12, y);
              ctx.font = '13px ui-monospace, monospace';
            }
          }
          if (b.grown >= b.len) {
            const swayX = Math.sin(t * 0.6 + b.seed) * b.sway;
            drawArt(b.x + swayX, baseY - 4 - b.len, b.type.art, b.type.color, bf);
          }
        }
        // bees drifting toward random blooms
        // bees use an offset above the footer line (oy) so they stay glued to the
        // garden — scrolling/fading with it instead of following the viewport.
        const bloomed = bottomStems.filter((s) => s.grown >= s.len);
        if (bees.length < 2 && Math.random() < 0.005 && bloomed.length) {
          const s = bloomed[Math.floor(Math.random() * bloomed.length)];
          bees.push({ x: Math.random() < 0.5 ? -20 : w + 20, oy: rand(80, 140), tx: s.x, toy: s.len + rand(4, 14), hover: 0, leaving: false, wob: rand(0, TAU), visits: Math.floor(rand(2, 5)) });
        }
        bees = bees.filter((be) => {
          be.wob += 0.08 * DT;
          const dx = be.tx - be.x, doy = be.toy - be.oy, dist = Math.hypot(dx, doy);
          be.x += dx * 0.005 * DT; be.oy += doy * 0.005 * DT;
          drawBee(be.x, baseY - be.oy + Math.sin(be.wob) * 3, dx, bf);
          if (!be.leaving && dist < 16) be.hover += DT;
          if (!be.leaving && dist < 16 && be.hover > 80) {
            be.hover = 0; be.visits--;
            if (be.visits > 0 && bloomed.length) {
              const s = bloomed[Math.floor(Math.random() * bloomed.length)];
              be.tx = s.x; be.toy = s.len + rand(4, 14); // hop to another bloom head
            } else {
              be.leaving = true; be.tx = be.x < w / 2 ? -40 : w + 40; be.toy = rand(70, 130);
            }
          }
          return !(be.leaving && (be.x < -30 || be.x > w + 30));
        });
      } else if (!bottomHidden) {
        // scrolled away from the bottom: wilt + reset so it regrows fresh next time
        bottomHidden = true; bees = [];
        bottomStems.forEach((b) => Object.assign(b, makeBottomStem(b.x)));
      }
    };

    /* ---------- driver ---------- */
    const motionOff = () => document.documentElement.getAttribute('data-motion') === 'off';
    let active = null, running = !motionOff(), raf = 0;
    const pick = () => {
      readColors();
      const light = document.documentElement.getAttribute('data-theme') === 'light';
      active = light ? { init: gardenInit, frame: gardenFrame } : { init: conInit, frame: conFrame };
      active.init();
    };
    const resize = () => {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      pick();
    };
    const frame = () => {
      if (!running) return;
      const now = performance.now();
      DT = Math.min(3, Math.max(0.2, (now - lastT) / 16.667));
      lastT = now;
      active.frame();
      raf = requestAnimationFrame(frame);
    };
    const onVis = () => { const was = running; running = !document.hidden && !motionOff(); if (running && !was) frame(); };
    window.addEventListener('resize', resize);
    const mo = new MutationObserver((muts) => {
      for (const m of muts) {
        if (m.attributeName === 'data-theme') pick();
        if (m.attributeName === 'data-motion') { const was = running; running = !motionOff() && !document.hidden; if (running && !was) frame(); }
      }
    });
    mo.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'data-motion'] });
    resize();

    if (reduce) { for (let s = 0; s < 300; s++) active.frame(); }
    else {
      document.addEventListener('visibilitychange', onVis);
      if (running) frame(); else active.frame();
    }

    // Teardown so re-init on navigation doesn't stack loops/listeners.
    return () => {
      running = false;
      cancelAnimationFrame(raf);
      window.removeEventListener('pointermove', onMove);
      window.removeEventListener('pointerleave', onLeave);
      window.removeEventListener('resize', resize);
      document.removeEventListener('visibilitychange', onVis);
      mo.disconnect();
    };
  }

  // (Re)start the garden whenever a page with #bg-canvas loads; tear down the
  // previous instance first (its canvas was detached by the view-transition swap).
  function initGarden() {
    if (window.__gardenTeardown) { window.__gardenTeardown(); window.__gardenTeardown = null; }
    const canvas = document.getElementById('bg-canvas');
    if (!canvas || !canvas.getContext) return; // not on the garden page
    window.__gardenTeardown = boot(canvas);
  }
  initGarden();
  document.addEventListener('astro:page-load', initGarden);
</script>
