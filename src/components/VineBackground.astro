---
---
<canvas id="bg-canvas" aria-hidden="true"></canvas>

<style is:global>
  #bg-canvas { position: fixed; inset: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
</style>

<script>
  const canvas = document.getElementById('bg-canvas');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && canvas.getContext) {
    const ctx = canvas.getContext('2d');
    let w = 0, h = 0;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const TAU = Math.PI * 2;
    const rand = (a, b) => a + Math.random() * (b - a);

    const css = (n, f) => getComputedStyle(document.documentElement).getPropertyValue(n).trim() || f;
    const hexToRgb = (hex) => {
      const m = hex.replace('#', '');
      const n = parseInt(m.length === 3 ? m.split('').map((c) => c + c).join('') : m, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };
    let ACCENT = [99, 102, 241], MUTED = [139, 148, 158], BG = [13, 17, 23];
    const readColors = () => {
      ACCENT = hexToRgb(css('--accent', '#6366f1'));
      MUTED = hexToRgb(css('--muted', '#8b949e'));
      BG = hexToRgb(css('--bg', '#0d1117'));
    };
    const rgba = (c, a) => `rgba(${c[0]},${c[1]},${c[2]},${a})`;

    const mouse = { x: -9999, y: -9999 };
    window.addEventListener('pointermove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
    window.addEventListener('pointerleave', () => { mouse.x = -9999; mouse.y = -9999; });

    /* ---------- Effect A: constellation + starfield (dark) ---------- */
    const LINK = 130;
    let particles = [], stars = [];
    const conInit = () => {
      const count = Math.min(90, Math.round((w * h) / 22000));
      particles = Array.from({ length: count }, () => ({
        x: Math.random() * w, y: Math.random() * h,
        vx: rand(-0.3, 0.3), vy: rand(-0.3, 0.3),
      }));
      const sc = Math.min(260, Math.round((w * h) / 6000));
      stars = Array.from({ length: sc }, () => {
        const z = Math.random();
        return { x: Math.random() * w, y: Math.random() * h, z, tw: rand(0, TAU) };
      });
    };
    const conFrame = () => {
      ctx.clearRect(0, 0, w, h);
      const t = performance.now() * 0.001;
      // starfield — parallax drift + twinkle
      for (const s of stars) {
        s.y += 0.05 + s.z * 0.35;
        if (s.y > h + 2) { s.y = -2; s.x = Math.random() * w; }
        const a = (0.25 + s.z * 0.5) * (0.6 + 0.4 * Math.sin(t * 1.5 + s.tw));
        ctx.beginPath(); ctx.arc(s.x, s.y, 0.5 + s.z * 1.3, 0, TAU);
        ctx.fillStyle = rgba(MUTED, a); ctx.fill();
      }
      // constellation
      for (const p of particles) {
        p.x += p.vx; p.y += p.vy;
        if (p.x < -10) p.x = w + 10; if (p.x > w + 10) p.x = -10;
        if (p.y < -10) p.y = h + 10; if (p.y > h + 10) p.y = -10;
      }
      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j], d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < LINK) { ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.strokeStyle = rgba(ACCENT, 0.14 * (1 - d / LINK)); ctx.lineWidth = 1; ctx.stroke(); }
        }
        ctx.beginPath(); ctx.arc(a.x, a.y, 1.6, 0, TAU); ctx.fillStyle = rgba(ACCENT, 0.5); ctx.fill();
      }
    };

    /* ---------- Effect B: hanging vine garland + flowers + fairy lights (light) ---------- */
    const STEM = [54, 110, 68], LEAF = [86, 148, 96], GLOW = [255, 214, 130];
    const FLOWERS = [[231, 84, 128], [239, 68, 68], [245, 158, 11], [168, 85, 247], [236, 72, 153], [250, 204, 21], [59, 130, 246]];
    let strands = [], lights = [];
    const t0 = performance.now();

    const CHARSET = '01{}[]()<>/\\;:*#+=$%&|!?~^'.split('');
    const STEPY = 16; // vertical char spacing
    const makeStrand = (x) => {
      const len = rand(140, 380);
      const chars = [];
      for (let d = STEPY; d < len; d += STEPY) chars.push({ d, ch: CHARSET[Math.floor(Math.random() * CHARSET.length)], flip: rand(0, 1) });
      return {
        x, len, seed: rand(0, TAU), curl: rand(8, 20), curlF: rand(0.012, 0.022), sway: rand(10, 22), chars,
        tip: Math.random() < 0.6 ? FLOWERS[Math.floor(Math.random() * FLOWERS.length)] : null,
      };
    };
    const gardenInit = () => {
      strands = []; lights = [];
      const gap = 130;
      for (let x = 0; x <= w; x += gap) strands.push(makeStrand(x + rand(-25, 25)));
      for (let k = 0; k < 5; k++) { strands.push(makeStrand(rand(0, 150))); strands.push(makeStrand(w - rand(0, 150))); }
      for (let x = 40; x < w; x += rand(60, 100)) lights.push({ x, phase: rand(0, TAU), ch: CHARSET[Math.floor(Math.random() * CHARSET.length)] });
    };

    const gardenFrame = () => {
      ctx.clearRect(0, 0, w, h);
      const t = (performance.now() - t0) * 0.001;
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';

      // top wire
      ctx.beginPath(); ctx.moveTo(0, 8);
      for (let x = 0; x <= w; x += 20) ctx.lineTo(x, 8 + Math.sin(x * 0.01) * 6);
      ctx.strokeStyle = rgba(STEM, 0.35); ctx.lineWidth = 1; ctx.stroke();

      // fairy-light glyphs on the wire
      ctx.font = '13px ui-monospace, monospace';
      for (const L of lights) {
        const y = 8 + Math.sin(L.x * 0.01) * 6;
        const tw = 0.5 + 0.5 * Math.sin(t * 2 + L.phase);
        ctx.fillStyle = rgba(GLOW, 0.35 + 0.6 * tw);
        ctx.fillText(L.ch, L.x, y);
      }

      // hanging strands of ascii
      ctx.font = '13px ui-monospace, monospace';
      for (const s of strands) {
        let lastX = s.x, lastY = 8;
        for (const c of s.chars) {
          const swayX = Math.sin(t * 0.6 + s.seed) * s.sway * (c.d / s.len);
          const x = s.x + Math.sin(c.d * s.curlF + s.seed) * s.curl + swayX;
          const y = 8 + c.d;
          const fade = 0.35 + 0.5 * (1 - c.d / s.len);
          // occasional flicker to a new glyph
          if (Math.random() < 0.01) c.ch = CHARSET[Math.floor(Math.random() * CHARSET.length)];
          ctx.fillStyle = rgba(STEM, fade);
          ctx.fillText(c.ch, x, y);
          lastX = x; lastY = y;
        }
        if (s.tip) {
          ctx.font = 'bold 15px ui-monospace, monospace';
          ctx.fillStyle = rgba(s.tip, 0.95);
          ctx.fillText('❀', lastX, lastY + STEPY);
          ctx.font = '13px ui-monospace, monospace';
        }
      }
    };

    /* ---------- driver ---------- */
    let active = null, running = true;
    const pick = () => {
      readColors();
      const light = document.documentElement.getAttribute('data-theme') === 'light';
      active = light ? { init: gardenInit, frame: gardenFrame } : { init: conInit, frame: conFrame };
      active.init();
    };
    const resize = () => {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      pick();
    };
    window.addEventListener('resize', resize);
    new MutationObserver(pick).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    resize();

    const frame = () => { if (!running) return; active.frame(); requestAnimationFrame(frame); };
    if (reduce) { for (let s = 0; s < 300; s++) active.frame(); }
    else {
      document.addEventListener('visibilitychange', () => { const was = running; running = !document.hidden; if (running && !was) frame(); });
      frame();
    }
  }
</script>
