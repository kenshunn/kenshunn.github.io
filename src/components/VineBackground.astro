---
---
<canvas id="bg-canvas" aria-hidden="true"></canvas>

<style is:global>
  #bg-canvas { position: fixed; inset: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
</style>

<script>
  const canvas = document.getElementById('bg-canvas');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && canvas.getContext) {
    const ctx = canvas.getContext('2d');
    let w = 0, h = 0;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const TAU = Math.PI * 2;
    const rand = (a, b) => a + Math.random() * (b - a);

    const css = (n, f) => getComputedStyle(document.documentElement).getPropertyValue(n).trim() || f;
    const hexToRgb = (hex) => {
      const m = hex.replace('#', '');
      const n = parseInt(m.length === 3 ? m.split('').map((c) => c + c).join('') : m, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };
    let ACCENT = [99, 102, 241], MUTED = [139, 148, 158], BG = [13, 17, 23];
    const readColors = () => {
      ACCENT = hexToRgb(css('--accent', '#6366f1'));
      MUTED = hexToRgb(css('--muted', '#8b949e'));
      BG = hexToRgb(css('--bg', '#0d1117'));
    };
    const rgba = (c, a) => `rgba(${c[0]},${c[1]},${c[2]},${a})`;

    const mouse = { x: -9999, y: -9999 };
    window.addEventListener('pointermove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
    window.addEventListener('pointerleave', () => { mouse.x = -9999; mouse.y = -9999; });

    /* ---------- Effect A: constellation + dot-grid + mouse (dark) ---------- */
    const GRID = 42, LINK = 130, MOUSE_R = 160;
    let particles = [];
    const conInit = () => {
      const count = Math.min(90, Math.round((w * h) / 22000));
      particles = Array.from({ length: count }, () => ({
        x: Math.random() * w, y: Math.random() * h,
        vx: rand(-0.35, 0.35), vy: rand(-0.35, 0.35),
      }));
    };
    const conFrame = () => {
      ctx.clearRect(0, 0, w, h);
      for (let x = GRID; x < w; x += GRID) for (let y = GRID; y < h; y += GRID) {
        const d = Math.hypot(x - mouse.x, y - mouse.y);
        if (d < MOUSE_R) { const t = 1 - d / MOUSE_R; ctx.beginPath(); ctx.arc(x, y, 1 + t * 1.6, 0, TAU); ctx.fillStyle = rgba(ACCENT, 0.15 + t * 0.5); ctx.fill(); }
        else { ctx.beginPath(); ctx.arc(x, y, 1, 0, TAU); ctx.fillStyle = rgba(MUTED, 0.12); ctx.fill(); }
      }
      for (const p of particles) {
        const dx = p.x - mouse.x, dy = p.y - mouse.y, d = Math.hypot(dx, dy);
        if (d < MOUSE_R && d > 0.01) { const f = (1 - d / MOUSE_R) * 0.6; p.vx += dx / d * f; p.vy += dy / d * f; }
        p.vx *= 0.98; p.vy *= 0.98;
        if (Math.abs(p.vx) < 0.05) p.vx = rand(-0.3, 0.3);
        if (Math.abs(p.vy) < 0.05) p.vy = rand(-0.3, 0.3);
        p.x += p.vx; p.y += p.vy;
        if (p.x < -10) p.x = w + 10; if (p.x > w + 10) p.x = -10;
        if (p.y < -10) p.y = h + 10; if (p.y > h + 10) p.y = -10;
      }
      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j], d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < LINK) { ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.strokeStyle = rgba(ACCENT, 0.14 * (1 - d / LINK)); ctx.lineWidth = 1; ctx.stroke(); }
        }
        const md = Math.hypot(a.x - mouse.x, a.y - mouse.y);
        if (md < MOUSE_R) { ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(mouse.x, mouse.y); ctx.strokeStyle = rgba(ACCENT, 0.2 * (1 - md / MOUSE_R)); ctx.stroke(); }
        ctx.beginPath(); ctx.arc(a.x, a.y, 1.6, 0, TAU); ctx.fillStyle = rgba(ACCENT, 0.5); ctx.fill();
      }
    };

    /* ---------- Effect B: hanging vine garland + flowers + fairy lights (light) ---------- */
    const STEM = [54, 110, 68], LEAF = [86, 148, 96], GLOW = [255, 214, 130];
    const FLOWERS = [[231, 84, 128], [239, 68, 68], [245, 158, 11], [168, 85, 247], [236, 72, 153], [250, 204, 21], [59, 130, 246]];
    let strands = [], lights = [];
    const t0 = performance.now();

    const makeStrand = (x) => {
      const len = rand(120, 340);
      const leaves = [];
      for (let d = 22; d < len - 8; d += rand(20, 34)) leaves.push({ d, side: Math.random() < 0.5 ? 1 : -1, size: rand(6, 11) });
      return {
        x, len, seed: rand(0, TAU), curl: rand(8, 20), curlF: rand(0.012, 0.022),
        sway: rand(10, 22), leaves,
        flower: Math.random() < 0.55 ? FLOWERS[Math.floor(Math.random() * FLOWERS.length)] : null,
      };
    };
    const gardenInit = () => {
      strands = []; lights = [];
      const gap = 150;
      for (let x = 0; x <= w; x += gap) strands.push(makeStrand(x + rand(-25, 25)));
      for (let k = 0; k < 5; k++) { strands.push(makeStrand(rand(0, 150))); strands.push(makeStrand(w - rand(0, 150))); }
      for (let x = 40; x < w; x += rand(70, 120)) lights.push({ x, phase: rand(0, TAU) });
    };

    const drawLeaf = (x, y, ang, size) => {
      ctx.save(); ctx.translate(x, y); ctx.rotate(ang);
      ctx.beginPath(); ctx.ellipse(0, 0, size, size * 0.5, 0, 0, TAU);
      ctx.fillStyle = rgba(LEAF, 0.85); ctx.fill();
      ctx.beginPath(); ctx.moveTo(-size, 0); ctx.lineTo(size, 0); ctx.strokeStyle = rgba(STEM, 0.5); ctx.lineWidth = 0.8; ctx.stroke();
      ctx.restore();
    };
    const drawFlower = (x, y, col) => {
      ctx.save(); ctx.translate(x, y);
      for (let i = 0; i < 6; i++) { const a = i / 6 * TAU; ctx.beginPath(); ctx.ellipse(Math.cos(a) * 5, Math.sin(a) * 5, 5, 3, a, 0, TAU); ctx.fillStyle = rgba(col, 0.9); ctx.fill(); }
      ctx.beginPath(); ctx.arc(0, 0, 3, 0, TAU); ctx.fillStyle = rgba([250, 204, 21], 0.95); ctx.fill();
      ctx.restore();
    };

    const gardenFrame = () => {
      ctx.clearRect(0, 0, w, h);
      const t = (performance.now() - t0) * 0.001;

      // top wire + fairy lights
      ctx.beginPath(); ctx.moveTo(0, 6);
      for (let x = 0; x <= w; x += 20) ctx.lineTo(x, 6 + Math.sin(x * 0.01) * 6);
      ctx.strokeStyle = rgba(STEM, 0.4); ctx.lineWidth = 1.2; ctx.stroke();
      for (const L of lights) {
        const y = 6 + Math.sin(L.x * 0.01) * 6 + 6;
        const tw = 0.55 + 0.45 * Math.sin(t * 2 + L.phase);
        const g = ctx.createRadialGradient(L.x, y, 0, L.x, y, 10);
        g.addColorStop(0, rgba(GLOW, 0.9 * tw)); g.addColorStop(1, rgba(GLOW, 0));
        ctx.fillStyle = g; ctx.beginPath(); ctx.arc(L.x, y, 10, 0, TAU); ctx.fill();
        ctx.fillStyle = rgba(GLOW, 0.9); ctx.beginPath(); ctx.arc(L.x, y, 1.8, 0, TAU); ctx.fill();
      }

      // hanging strands
      for (const s of strands) {
        let px = s.x, py = 4;
        ctx.beginPath(); ctx.moveTo(px, py);
        for (let d = 0; d <= s.len; d += 6) {
          const swayX = Math.sin(t * 0.6 + s.seed) * s.sway * (d / s.len);
          const x = s.x + Math.sin(d * s.curlF + s.seed) * s.curl + swayX;
          const y = 4 + d;
          ctx.lineTo(x, y); px = x; py = y;
        }
        ctx.strokeStyle = rgba(STEM, 0.8); ctx.lineWidth = 2; ctx.stroke();

        for (const lf of s.leaves) {
          const swayX = Math.sin(t * 0.6 + s.seed) * s.sway * (lf.d / s.len);
          const x = s.x + Math.sin(lf.d * s.curlF + s.seed) * s.curl + swayX;
          const y = 4 + lf.d;
          drawLeaf(x + lf.side * lf.size * 0.6, y, lf.side > 0 ? -0.5 : 0.5, lf.size);
        }
        if (s.flower) drawFlower(px, py, s.flower);
      }
    };

    /* ---------- driver ---------- */
    let active = null, running = true;
    const pick = () => {
      readColors();
      const light = document.documentElement.getAttribute('data-theme') === 'light';
      active = light ? { init: gardenInit, frame: gardenFrame } : { init: conInit, frame: conFrame };
      active.init();
    };
    const resize = () => {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      pick();
    };
    window.addEventListener('resize', resize);
    new MutationObserver(pick).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    resize();

    const frame = () => { if (!running) return; active.frame(); requestAnimationFrame(frame); };
    if (reduce) { for (let s = 0; s < 300; s++) active.frame(); }
    else {
      document.addEventListener('visibilitychange', () => { const was = running; running = !document.hidden; if (running && !was) frame(); });
      frame();
    }
  }
</script>
