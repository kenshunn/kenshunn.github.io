---
---
<canvas id="bg-canvas" aria-hidden="true"></canvas>

<style is:global>
  #bg-canvas { position: fixed; inset: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
</style>

<script>
  const canvas = document.getElementById('bg-canvas');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && canvas.getContext) {
    const ctx = canvas.getContext('2d');
    let w = 0, h = 0;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const TAU = Math.PI * 2;
    const rand = (a, b) => a + Math.random() * (b - a);

    const css = (n, f) => getComputedStyle(document.documentElement).getPropertyValue(n).trim() || f;
    const hexToRgb = (hex) => {
      const m = hex.replace('#', '');
      const n = parseInt(m.length === 3 ? m.split('').map((c) => c + c).join('') : m, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };
    let ACCENT = [99, 102, 241], MUTED = [139, 148, 158], BG = [13, 17, 23];
    const readColors = () => {
      ACCENT = hexToRgb(css('--accent', '#6366f1'));
      MUTED = hexToRgb(css('--muted', '#8b949e'));
      BG = hexToRgb(css('--bg', '#0d1117'));
    };
    const rgba = (c, a) => `rgba(${c[0]},${c[1]},${c[2]},${a})`;

    const mouse = { x: -9999, y: -9999 };
    window.addEventListener('pointermove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
    window.addEventListener('pointerleave', () => { mouse.x = -9999; mouse.y = -9999; });

    /* ---------- Effect A: constellation + starfield (dark) ---------- */
    const LINK = 130;
    let particles = [];
    const conInit = () => {
      const count = Math.min(90, Math.round((w * h) / 22000));
      particles = Array.from({ length: count }, () => ({
        x: Math.random() * w, y: Math.random() * h,
        vx: rand(-0.3, 0.3), vy: rand(-0.3, 0.3),
      }));
    };
    const conFrame = () => {
      ctx.clearRect(0, 0, w, h);
      for (const p of particles) {
        p.x += p.vx; p.y += p.vy;
        if (p.x < -10) p.x = w + 10; if (p.x > w + 10) p.x = -10;
        if (p.y < -10) p.y = h + 10; if (p.y > h + 10) p.y = -10;
      }
      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j], d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < LINK) { ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.strokeStyle = rgba(ACCENT, 0.14 * (1 - d / LINK)); ctx.lineWidth = 1; ctx.stroke(); }
        }
        ctx.beginPath(); ctx.arc(a.x, a.y, 1.6, 0, TAU); ctx.fillStyle = rgba(ACCENT, 0.5); ctx.fill();
      }
    };

    /* ---------- Effect B: hanging vine garland + flowers + fairy lights (light) ---------- */
    const STEM = [54, 110, 68], LEAF = [86, 148, 96], GLOW = [255, 214, 130];
    const FLOWERS = [[231, 84, 128], [239, 68, 68], [245, 158, 11], [168, 85, 247], [236, 72, 153], [250, 204, 21], [59, 130, 246]];
    let strands = [], lights = [];
    const t0 = performance.now();

    const CHARSET = '01{}[]()<>/\\;:*#+=$%&|!?~^'.split('');
    const STEPY = 16; // vertical char spacing
    let falling = [];
    const randChar = () => CHARSET[Math.floor(Math.random() * CHARSET.length)];
    const fillChars = (len) => {
      const chars = [];
      for (let d = STEPY; d < len; d += STEPY) chars.push({ d, ch: randChar() });
      return chars;
    };
    const makeStrand = (x) => {
      const len = rand(150, 380);
      return {
        x, len, seed: rand(0, TAU), curl: rand(8, 20), curlF: rand(0.012, 0.022), sway: rand(10, 22),
        chars: fillChars(len),
        tip: Math.random() < 0.7 ? FLOWERS[Math.floor(Math.random() * FLOWERS.length)] : null,
        grown: 0, growSpeed: rand(1.6, 3.4), state: 'grow', alpha: 1, hold: 0, delay: rand(0, 160),
      };
    };
    const resetStrand = (s) => {
      s.len = rand(150, 380); s.chars = fillChars(s.len); s.seed = rand(0, TAU);
      s.tip = Math.random() < 0.7 ? FLOWERS[Math.floor(Math.random() * FLOWERS.length)] : null;
      s.grown = 0; s.growSpeed = rand(1.6, 3.4); s.state = 'grow'; s.alpha = 1; s.hold = 0; s.delay = rand(20, 140);
    };
    const gardenInit = () => {
      strands = []; lights = []; falling = [];
      const gap = 130;
      for (let x = 0; x <= w; x += gap) strands.push(makeStrand(x + rand(-25, 25)));
      for (let k = 0; k < 5; k++) { strands.push(makeStrand(rand(0, 150))); strands.push(makeStrand(w - rand(0, 150))); }
      for (let x = 40; x < w; x += rand(60, 100)) lights.push({ x, phase: rand(0, TAU), ch: randChar() });
    };
    const strandX = (s, d, t) => s.x + Math.sin(d * s.curlF + s.seed) * s.curl + Math.sin(t * 0.6 + s.seed) * s.sway * (d / s.len);

    const gardenFrame = () => {
      ctx.clearRect(0, 0, w, h);
      const t = (performance.now() - t0) * 0.001;
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';

      // top wire
      ctx.beginPath(); ctx.moveTo(0, 8);
      for (let x = 0; x <= w; x += 20) ctx.lineTo(x, 8 + Math.sin(x * 0.01) * 6);
      ctx.strokeStyle = rgba(STEM, 0.35); ctx.lineWidth = 1; ctx.stroke();

      // fairy-light glyphs
      ctx.font = '13px ui-monospace, monospace';
      for (const L of lights) {
        const y = 8 + Math.sin(L.x * 0.01) * 6;
        const tw = 0.5 + 0.5 * Math.sin(t * 2 + L.phase);
        ctx.fillStyle = rgba(GLOW, 0.35 + 0.6 * tw);
        ctx.fillText(L.ch, L.x, y);
      }

      // strands lifecycle: grow -> hold -> flower drops -> fade -> regrow
      ctx.font = '13px ui-monospace, monospace';
      for (const s of strands) {
        if (s.delay > 0) { s.delay--; continue; }

        if (s.state === 'grow') {
          s.grown += s.growSpeed;
          if (s.grown >= s.len) { s.grown = s.len; s.state = 'hold'; s.hold = 40; }
        } else if (s.state === 'hold') {
          if (--s.hold <= 0) {
            s.state = 'fade';
            if (s.tip) falling.push({ x: strandX(s, s.len, t), y: 8 + s.len, vy: rand(0.5, 1.1), alpha: 1, color: s.tip, rot: 0, rotV: rand(-0.06, 0.06) });
          }
        } else if (s.state === 'fade') {
          s.alpha -= 0.02;
          if (s.alpha <= 0) resetStrand(s);
        }

        for (const c of s.chars) {
          if (c.d > s.grown) break;
          const x = strandX(s, c.d, t);
          const y = 8 + c.d;
          if (Math.random() < 0.01) c.ch = randChar();
          const depthFade = 0.35 + 0.5 * (1 - c.d / s.len);
          ctx.fillStyle = rgba(STEM, depthFade * s.alpha);
          ctx.fillText(c.ch, x, y);
        }
        // static tip bloom only while fully grown & holding (before it drops)
        if (s.tip && s.state === 'hold') {
          ctx.font = 'bold 15px ui-monospace, monospace';
          ctx.fillStyle = rgba(s.tip, 0.95 * s.alpha);
          ctx.fillText('❀', strandX(s, s.len, t), 8 + s.len + STEPY);
          ctx.font = '13px ui-monospace, monospace';
        }
      }

      // falling flowers
      ctx.font = 'bold 15px ui-monospace, monospace';
      falling = falling.filter((f) => {
        f.vy += 0.02; f.y += f.vy; f.alpha -= 0.006; f.rot += f.rotV;
        if (f.alpha <= 0 || f.y > h + 20) return false;
        ctx.save(); ctx.translate(f.x, f.y); ctx.rotate(f.rot);
        ctx.fillStyle = rgba(f.color, Math.max(0, f.alpha));
        ctx.fillText('❀', 0, 0); ctx.restore();
        return true;
      });
      ctx.font = '13px ui-monospace, monospace';
    };

    /* ---------- driver ---------- */
    let active = null, running = true;
    const pick = () => {
      readColors();
      const light = document.documentElement.getAttribute('data-theme') === 'light';
      active = light ? { init: gardenInit, frame: gardenFrame } : { init: conInit, frame: conFrame };
      active.init();
    };
    const resize = () => {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      pick();
    };
    window.addEventListener('resize', resize);
    new MutationObserver(pick).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    resize();

    const frame = () => { if (!running) return; active.frame(); requestAnimationFrame(frame); };
    if (reduce) { for (let s = 0; s < 300; s++) active.frame(); }
    else {
      document.addEventListener('visibilitychange', () => { const was = running; running = !document.hidden; if (running && !was) frame(); });
      frame();
    }
  }
</script>
