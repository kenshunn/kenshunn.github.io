---
---
<canvas id="vines" aria-hidden="true"></canvas>

<style is:global>
  #vines {
    position: fixed; inset: 0; width: 100%; height: 100%;
    z-index: -1; pointer-events: none; opacity: 0.5;
  }
</style>

<script>
  const canvas = document.getElementById('vines');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (canvas && canvas.getContext) {
    const ctx = canvas.getContext('2d');
    let w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);

    const css = (name, fallback) =>
      getComputedStyle(document.documentElement).getPropertyValue(name).trim() || fallback;
    let ACCENT = css('--accent', '#6366f1');
    let BG = css('--bg', '#0d1117');

    const hexToRgb = (hex) => {
      const m = hex.replace('#', '');
      const n = parseInt(m.length === 3 ? m.split('').map((c) => c + c).join('') : m, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };

    const resize = () => {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const [r, g, b] = hexToRgb(BG);
      ctx.fillStyle = `rgb(${r},${g},${b})`;
      ctx.fillRect(0, 0, w, h);
    };
    window.addEventListener('resize', () => { BG = css('--bg', '#0d1117'); ACCENT = css('--accent', '#6366f1'); resize(); });
    resize();

    const rand = (a, b) => a + Math.random() * (b - a);
    const TAU = Math.PI * 2;

    function spawn() {
      // start from a random screen edge, aim inward
      const edge = Math.floor(rand(0, 4));
      let x, y, angle;
      if (edge === 0) { x = rand(0, w); y = -10; angle = rand(0.2, Math.PI - 0.2); }
      else if (edge === 1) { x = w + 10; y = rand(0, h); angle = rand(Math.PI * 0.6, Math.PI * 1.4); }
      else if (edge === 2) { x = rand(0, w); y = h + 10; angle = rand(Math.PI + 0.2, TAU - 0.2); }
      else { x = -10; y = rand(0, h); angle = rand(-Math.PI * 0.4, Math.PI * 0.4); }
      return {
        x, y, angle,
        seed: rand(0, 1000),
        curlAmp: rand(0.02, 0.06),
        curlFreq: rand(0.01, 0.03),
        speed: rand(0.5, 1.0),
        len: 0,
        maxLen: rand(280, 620),
        thornAcc: 0,
        depth: 0,
      };
    }

    let vines = [];
    const MAX = 8;
    const roseColor = () => ACCENT;

    function bloom(x, y) {
      // small rose: layered arcs
      const petals = 5;
      const base = rand(3, 5);
      ctx.save();
      ctx.translate(x, y);
      for (let ring = 3; ring >= 1; ring--) {
        ctx.beginPath();
        for (let i = 0; i < petals; i++) {
          const a = (i / petals) * TAU + ring;
          const rr = base * ring * 0.6;
          ctx.moveTo(0, 0);
          ctx.arc(Math.cos(a) * rr * 0.4, Math.sin(a) * rr * 0.4, rr * 0.5, 0, TAU);
        }
        ctx.fillStyle = roseColor();
        ctx.globalAlpha = 0.18 * ring / 3 + 0.06;
        ctx.fill();
      }
      ctx.restore();
      ctx.globalAlpha = 1;
    }

    function grow(v) {
      const px = v.x, py = v.y;
      v.angle += Math.sin(v.len * v.curlFreq + v.seed) * v.curlAmp;
      v.x += Math.cos(v.angle) * v.speed;
      v.y += Math.sin(v.angle) * v.speed;
      v.len += v.speed;

      // stem
      ctx.beginPath();
      ctx.moveTo(px, py);
      ctx.lineTo(v.x, v.y);
      ctx.strokeStyle = ACCENT;
      ctx.globalAlpha = 0.22;
      ctx.lineWidth = Math.max(0.6, 1.6 - v.depth * 0.4);
      ctx.stroke();

      // thorns
      v.thornAcc += v.speed;
      if (v.thornAcc > 16) {
        v.thornAcc = 0;
        const side = Math.random() < 0.5 ? 1 : -1;
        const na = v.angle + side * Math.PI / 2;
        const tl = rand(3, 6);
        ctx.beginPath();
        ctx.moveTo(v.x, v.y);
        ctx.lineTo(v.x + Math.cos(na) * tl, v.y + Math.sin(na) * tl);
        ctx.globalAlpha = 0.28;
        ctx.stroke();
      }

      // branch occasionally
      if (v.depth < 2 && vines.length < MAX && Math.random() < 0.006) {
        const b = spawn();
        b.x = v.x; b.y = v.y;
        b.angle = v.angle + rand(-0.9, 0.9);
        b.depth = v.depth + 1;
        b.maxLen = v.maxLen * 0.6;
        b.speed = v.speed * 0.9;
        vines.push(b);
      }

      ctx.globalAlpha = 1;

      const off = v.x < -40 || v.x > w + 40 || v.y < -40 || v.y > h + 40;
      if (v.len >= v.maxLen || off) {
        if (!off) bloom(v.x, v.y); // bloom a rose where it matured
        return false;
      }
      return true;
    }

    const [br, bgc, bb] = hexToRgb(BG);
    let running = true;

    function frame() {
      if (!running) return;
      // gentle fade so old growth dissolves -> continuous renewal
      ctx.fillStyle = `rgba(${br},${bgc},${bb},0.035)`;
      ctx.fillRect(0, 0, w, h);

      vines = vines.filter(grow);
      while (vines.length < 3) vines.push(spawn());

      requestAnimationFrame(frame);
    }

    if (reduce) {
      for (let i = 0; i < 6; i++) vines.push(spawn());
      for (let s = 0; s < 400; s++) vines = vines.filter(grow);
    } else {
      document.addEventListener('visibilitychange', () => {
        const wasRunning = running;
        running = !document.hidden;
        if (running && !wasRunning) frame();
      });
      frame();
    }
  }
</script>
