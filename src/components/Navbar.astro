---
const links = [
  { href: '/', label: 'Home', icon: 'home' },
  { href: '/about', label: 'About', icon: 'user' },
  { href: '/experience', label: 'Experience', icon: 'briefcase' },
  { href: '/skills', label: 'Skills', icon: 'code' },
  { href: '/projects', label: 'Projects', icon: 'grid' },
  { href: '/garden', label: 'Garden', icon: 'sprout' },
  { href: '/contact', label: 'Contact', icon: 'mail' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href) => path === href;
---

<nav class="dock" aria-label="Primary">
  <ul class="dock-items">
    {links.map((l) => (
      <li>
        <a
          href={l.href}
          class={`dock-item${isActive(l.href) ? ' active' : ''}`}
          data-label={l.label}
          aria-label={l.label}
          aria-current={isActive(l.href) ? 'page' : undefined}
        >
          {l.icon === 'home' && <svg viewBox="0 0 24 24"><path d="M3 11.5 12 4l9 7.5"></path><path d="M5 10v10h14V10"></path></svg>}
          {l.icon === 'user' && <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"></circle><path d="M4 21c0-4 3.6-7 8-7s8 3 8 7"></path></svg>}
          {l.icon === 'briefcase' && <svg viewBox="0 0 24 24"><rect x="3" y="7.5" width="18" height="12" rx="2"></rect><path d="M8.5 7.5V6a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v1.5"></path><path d="M3 12.5h18"></path></svg>}
          {l.icon === 'code' && <svg viewBox="0 0 24 24"><path d="M8.5 8 4 12l4.5 4"></path><path d="M15.5 8 20 12l-4.5 4"></path></svg>}
          {l.icon === 'grid' && <svg viewBox="0 0 24 24"><rect x="4" y="4" width="7" height="7" rx="1.5"></rect><rect x="13" y="4" width="7" height="7" rx="1.5"></rect><rect x="4" y="13" width="7" height="7" rx="1.5"></rect><rect x="13" y="13" width="7" height="7" rx="1.5"></rect></svg>}
          {l.icon === 'sprout' && <svg viewBox="0 0 24 24"><path d="M12 20v-8"></path><path d="M12 12C12 8 9 5.5 4.5 5.5 4.5 10 7.5 12 12 12Z"></path><path d="M12 12c0-3 2.5-5 6.5-5 0 4-2.5 5-6.5 5Z"></path></svg>}
          {l.icon === 'mail' && <svg viewBox="0 0 24 24"><rect x="3" y="5.5" width="18" height="13" rx="2"></rect><path d="m4 7 8 6 8-6"></path></svg>}
        </a>
      </li>
    ))}
    <li class="dock-sep" aria-hidden="true"></li>
    <li>
      <button type="button" id="theme-toggle" class="dock-item" data-label="Theme" role="switch" aria-label="Toggle color theme">
        <svg class="ico-sun" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
        <svg class="ico-moon" viewBox="0 0 24 24"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"></path></svg>
      </button>
    </li>
  </ul>
</nav>

<script>
  // Delegated on document so it survives view-transition navigations.
  if (!window.__navBound) {
    window.__navBound = true;
    document.addEventListener('click', (e) => {
      if (e.target.closest('#theme-toggle')) {
        const cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', cur);
        try { localStorage.setItem('theme', cur); } catch (err) { /* ignore */ }
      }
    });
  }
</script>
