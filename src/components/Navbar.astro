---
const links = [
  { href: '/about', label: 'About' },
  { href: '/experience', label: 'Experience' },
  { href: '/skills', label: 'Skills' },
  { href: '/projects', label: 'Projects' },
  { href: '/garden', label: 'Garden' },
  { href: '/contact', label: 'Contact' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href) => path === href;
---

<nav class="navbar">
  <a href="/" class="logo">@kenshunn</a>

  <ul class="nav-links desktop-only">
    {links.map((l) => <li><a href={l.href} class={isActive(l.href) ? 'active' : ''} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a></li>)}
  </ul>

  <div class="nav-right">
    <button type="button" id="theme-toggle" class="theme-switch" role="switch" aria-label="Toggle color theme">
      <svg class="ico-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
      </svg>
      <svg class="ico-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"></path>
      </svg>
      <span class="knob"></span>
    </button>
    <button type="button" class="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <ul class="mobile-menu">
    {links.map((l) => <li><a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a></li>)}
  </ul>
</nav>

<script>
  // Delegated on document so it survives view-transition navigations
  // (the navbar DOM is swapped on each page change). Guard to bind once.
  if (!window.__navBound) {
    window.__navBound = true;
    document.addEventListener('click', (e) => {
      const t = e.target;
      if (t.closest('.hamburger')) {
        document.querySelector('.mobile-menu')?.classList.toggle('open');
        return;
      }
      if (t.closest('.mobile-menu a')) {
        document.querySelector('.mobile-menu')?.classList.remove('open');
        return;
      }
      if (t.closest('#theme-toggle')) {
        const cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', cur);
        try { localStorage.setItem('theme', cur); } catch (err) { /* ignore */ }
      }
    });
  }
</script>
