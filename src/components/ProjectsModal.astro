---
import projects from '../data/projects.js';
---
<div class="pm-modal" id="projects-modal" role="dialog" aria-modal="true" aria-label="All projects" hidden>
  <div class="pm-backdrop" data-pm-close></div>
  <div class="pm-box">
    <div class="pm-head">
      <h3>All Projects</h3>
      <button type="button" class="pm-close" aria-label="Close" data-pm-close>&times;</button>
    </div>
    <div class="pm-grid">
      {projects.map((p) => (
        <article class="pm-card">
          {p.featured && <span class="pm-badge">★ Featured</span>}
          <img class="pm-img" src={p.image} alt={p.title} />
          <h4>{p.title}</h4>
          <ul class="tags">
            {p.tags.map((t) => <li>{t}</li>)}
          </ul>
          <div class="pm-links">
            {p.liveUrl && (
              <a class="btn btn-primary" href={p.liveUrl} target="_blank" rel="noreferrer">Live</a>
            )}
            <button type="button" class="btn btn-outline repo-open" data-repo={p.repoUrl} data-title={p.title}>Code</button>
          </div>
        </article>
      ))}
    </div>
  </div>
</div>

<style>
  .pm-modal { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; padding: 1.5rem; }
  .pm-modal[hidden] { display: none; }
  .pm-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.65); backdrop-filter: blur(2px); }
  .pm-box {
    position: relative; display: flex; flex-direction: column;
    width: min(900px, 100%); max-height: 88vh;
    background: var(--surface); color: var(--text);
    border: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
    border-radius: 1rem; overflow: hidden;
  }
  .pm-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem 1.5rem; border-bottom: 1px solid color-mix(in srgb, var(--muted) 20%, transparent);
  }
  .pm-close { background: none; border: none; color: var(--muted); font-size: 1.7rem; line-height: 1; cursor: pointer; }
  .pm-close:hover { color: var(--text); }

  /* 2 per row, seamless scroll (hidden bar + fade edges) */
  .pm-grid {
    overflow-y: auto; padding: 1.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
    scrollbar-width: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 3%, #000 97%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0, #000 3%, #000 97%, transparent 100%);
  }
  .pm-grid::-webkit-scrollbar { display: none; }
  @media (max-width: 640px) { .pm-grid { grid-template-columns: 1fr; } }

  .pm-card {
    position: relative; display: flex; flex-direction: column;
    background: var(--bg); border-radius: 0.85rem; padding: 1.1rem;
    border: 1px solid color-mix(in srgb, var(--muted) 25%, transparent);
  }
  .pm-img { width: 100%; height: 120px; object-fit: contain; padding: 0.5rem; border-radius: 0.6rem; background: #0d1117; margin-bottom: 0.8rem; }
  .pm-card h4 { margin-bottom: 0.5rem; }
  .pm-links { display: flex; gap: 0.6rem; margin-top: auto; justify-content: flex-end; }
  .pm-links .btn { padding: 0.45rem 0.95rem; }
  .pm-badge {
    position: absolute; top: 0.7rem; right: 0.7rem; z-index: 2;
    font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.5rem; border-radius: 1rem;
    background: var(--accent); color: #fff;
  }
</style>

<script>
  const modal = document.getElementById('projects-modal');
  const toggle = document.getElementById('projects-grid-toggle');
  const open = () => { modal?.removeAttribute('hidden'); document.body.style.overflow = 'hidden'; };
  const close = () => { modal?.setAttribute('hidden', ''); document.body.style.overflow = ''; };
  toggle?.addEventListener('click', open);
  modal?.querySelectorAll('[data-pm-close]').forEach((el) => el.addEventListener('click', close));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.hasAttribute('hidden')) close();
  });
</script>
