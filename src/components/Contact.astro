---
---
<section id="contact" class="contact reveal screen">
  <p class="eyebrow">Get in touch</p>
  <h2>Contact Me</h2>
  <form class="contact-form" method="POST" novalidate>
    <input name="name" type="text" placeholder="Your name" aria-label="Name" />
    <input name="email" type="email" placeholder="Your email" aria-label="Email" />
    <textarea name="message" rows="5" placeholder="Your message" aria-label="Message"></textarea>
    <p class="form-error" role="alert"></p>
    <button type="submit" class="btn btn-primary">Send</button>
    <p class="form-ok" role="status"></p>
    <div class="contact-fallback">
      <a href="mailto:aaron.11demartin@gmail.com">aaron.11demartin@gmail.com</a>
      <span>+63 998 545 1812</span>
    </div>
  </form>
</section>

<style is:global>
  .contact { text-align: left; align-items: flex-start; }
  .contact-form {
    display: flex; flex-direction: column; gap: 1.1rem;
    width: 100%; max-width: 640px; margin: 2.5rem auto 0 0;
    text-align: left;
  }
  .contact-form input,
  .contact-form textarea {
    width: 100%; padding: 1.05rem 1.2rem; font-size: 1.05rem;
  }
  .contact-form textarea { resize: vertical; min-height: 180px; }
  .contact-form .btn { width: 100%; padding: 0.95rem; font-size: 1.02rem; margin-top: 0.25rem; }
  .form-error { min-height: 0; }
  .form-ok { color: var(--accent); font-family: var(--font-mono); font-size: 0.85rem; margin: 0; }
  .form-ok:empty { display: none; }
  .contact-fallback {
    display: flex; flex-wrap: wrap; justify-content: flex-start; gap: 1.25rem;
    margin-top: 1rem; padding-top: 1.25rem; border-top: 1px solid var(--hair);
    color: var(--muted); font-size: 0.95rem;
  }
</style>

<script>
  import validateContact from '../scripts/validate.js';
  const EMAIL = 'aaron.11demartin@gmail.com';
  const form = document.querySelector('.contact-form') as HTMLFormElement | null;
  const alert = document.querySelector('.contact-form .form-error');
  const ok = document.querySelector('.contact-form .form-ok');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (alert) alert.textContent = '';
    if (ok) ok.textContent = '';
    const data = {
      name: (form.elements.namedItem('name') as HTMLInputElement).value,
      email: (form.elements.namedItem('email') as HTMLInputElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
    };
    const { valid, error } = validateContact(data);
    if (!valid) {
      if (alert) alert.textContent = error;
      return;
    }
    const subject = `Portfolio contact from ${data.name}`;
    const body = `${data.message}\n\n— ${data.name} (${data.email})`;
    const href = `mailto:${EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = href;
    if (ok) ok.textContent = 'Opening your email app…';
    form.reset();
  });
</script>
