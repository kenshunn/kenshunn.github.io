---
import projects from '../data/projects.js';
---
<section id="projects" class="projects reveal">
  <p class="eyebrow">Browse my</p>
  <h2>Projects</h2>
  <div class="project-carousel">
    <button type="button" class="carousel-btn prev" aria-label="Previous projects">&#8249;</button>
    <div class="project-viewport">
      <div class="project-track">
        {projects.map((p) => (
          <article class="card project-card">
            <img class="project-img" src={p.image} alt={p.title} draggable="false" />
            <h3>{p.title}</h3>
            <p class="project-desc">{p.description}</p>
            <ul class="tags">
              {p.tags.map((t) => <li>{t}</li>)}
            </ul>
            <div class="project-links">
              <a class="btn btn-outline" href={p.repoUrl} target="_blank" rel="noreferrer">Code</a>
              {p.liveUrl && (
                <a class="btn btn-primary" href={p.liveUrl} target="_blank" rel="noreferrer">Live</a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
    <button type="button" class="carousel-btn next" aria-label="Next projects">&#8250;</button>
  </div>
</section>

<style>
  .project-carousel { position: relative; }
  .project-track { touch-action: pan-y; cursor: grab; user-select: none; }
  .project-track.grabbing { cursor: grabbing; }
  .carousel-btn {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 5;
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: var(--surface); color: var(--text);
    border: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
    font-size: 1.6rem; line-height: 1; cursor: pointer;
    transition: background 200ms ease, color 200ms ease, border-color 200ms ease;
  }
  .carousel-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
  .carousel-btn.prev { left: -8px; }
  .carousel-btn.next { right: -8px; }
  @media (max-width: 600px) {
    .carousel-btn.prev { left: 0; }
    .carousel-btn.next { right: 0; }
  }
</style>

<script>
  const wrap = document.querySelector('.project-carousel');
  const track = wrap?.querySelector('.project-track');

  if (wrap && track && track.children.length > 0) {
    const EASE = 0.2;     // glide stiffness — higher = snappier
    let pos = 0;          // current translateX (px)
    let target = 0;       // where pos is gliding to
    let raf = null;
    let dragging = false;
    let startX = 0, startPos = 0, moved = 0;

    const step = () => {
      const card = track.querySelector('.project-card');
      const gap = parseFloat(getComputedStyle(track).columnGap || '24') || 24;
      return card.getBoundingClientRect().width + gap;
    };
    const setX = (x) => { track.style.transform = `translateX(${x}px)`; };

    // Recycle cards through the DOM to keep pos within (-step, 0]. Each rotation
    // shifts BOTH pos and target by one card, so the remaining distance and the
    // on-screen pixels are preserved -> seamless infinite loop in both directions.
    const rebalance = () => {
      const s = step();
      let g = 0;
      while (pos <= -s && g++ < 300) { track.appendChild(track.firstElementChild); pos += s; target += s; }
      while (pos > 0 && g++ < 300) { track.insertBefore(track.lastElementChild, track.firstElementChild); pos -= s; target -= s; }
    };

    const tick = () => {
      pos += (target - pos) * EASE;
      if (Math.abs(target - pos) < 0.5) pos = target;
      rebalance();
      setX(pos);
      raf = pos === target ? null : requestAnimationFrame(tick);
    };
    const glide = () => { if (!raf) raf = requestAnimationFrame(tick); };

    // --- Arrows: each press pushes the target one more card; spam = fast multi-card glide ---
    const nudge = (dir) => {
      if (dragging) return;
      target += dir > 0 ? -step() : step();
      glide();
    };
    wrap.querySelector('.carousel-btn.next')?.addEventListener('click', () => nudge(1));
    wrap.querySelector('.carousel-btn.prev')?.addEventListener('click', () => nudge(-1));

    // --- Pointer drag (mouse hold + touch swipe), shares the same physics ---
    const onDown = (e) => {
      dragging = true; moved = 0;
      startX = e.clientX; startPos = pos;
      if (raf) { cancelAnimationFrame(raf); raf = null; }
      track.classList.add('grabbing');
      track.setPointerCapture?.(e.pointerId);
    };
    const onMove = (e) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      moved = Math.max(moved, Math.abs(dx));
      pos = startPos + dx;
      target = pos;
      rebalance();
      setX(pos);
    };
    const onUp = () => {
      if (!dragging) return;
      dragging = false;
      track.classList.remove('grabbing');
      const s = step();
      rebalance();
      target = pos < -s / 2 ? -s : 0; // snap to nearest card, then glide
      glide();
    };
    track.addEventListener('pointerdown', onDown);
    track.addEventListener('pointermove', onMove);
    track.addEventListener('pointerup', onUp);
    track.addEventListener('pointercancel', onUp);

    // Swallow the click that follows a real drag so card links don't fire mid-swipe.
    track.addEventListener('click', (e) => {
      if (moved > 6) { e.preventDefault(); e.stopPropagation(); }
    }, true);
  }
</script>
