---
import projects from '../data/projects.js';
import Coursework from './Coursework.astro';
const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
const projJson = (p) =>
  JSON.stringify({ title: p.title, description: p.longDescription || p.description, tags: p.tags, image: p.image, gallery: p.gallery || [], repoUrl: p.repoUrl, liveUrl: p.liveUrl || '' });
---
<section id="projects" class="projects reveal">
  <div class="projects-head">
    <div>
      <p class="eyebrow">Browse my</p>
      <h2>Projects</h2>
    </div>
    <button type="button" class="projects-grid-toggle" id="projects-grid-toggle" aria-label="View all projects">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
        <rect x="3" y="3" width="8" height="8" rx="1.5"></rect>
        <rect x="13" y="3" width="8" height="8" rx="1.5"></rect>
        <rect x="3" y="13" width="8" height="8" rx="1.5"></rect>
        <rect x="13" y="13" width="8" height="8" rx="1.5"></rect>
      </svg>
    </button>
  </div>

  {featured.length > 0 && (
    <div class="featured-rows">
      {featured.map((p) => (
        <article class="featured-row">
          <div class="featured-media project-open" role="button" tabindex="0" data-project={projJson(p)}>
            <span class="featured-badge">★ Featured</span>
            <img class="featured-img" src={p.image} alt={p.title} draggable="false" width="520" height="300" loading="lazy" />
          </div>
          <div class="featured-body">
            {p.meta && (
              <dl class="featured-meta">
                <div><dt>Role</dt><dd>{p.meta.role}</dd></div>
                <div><dt>Focus</dt><dd>{p.meta.focus}</dd></div>
                <div><dt>Output</dt><dd>{p.meta.output}</dd></div>
              </dl>
            )}
            <h3>{p.title}</h3>
            <p class="project-desc">{p.description}</p>
            <ul class="tags">
              {p.tags.map((t) => <li>{t}</li>)}
            </ul>
            <div class="project-links">
              {p.liveUrl && (
                <a class="btn btn-primary" href={p.liveUrl} target="_blank" rel="noreferrer">Live</a>
              )}
              <button type="button" class="btn btn-outline repo-open" data-repo={p.repoUrl} data-title={p.title}>Code</button>
            </div>
          </div>
        </article>
      ))}
    </div>
  )}

  <div class="project-carousel">
    <button type="button" class="carousel-btn prev" aria-label="Previous projects">&#8249;</button>
    <div class="project-viewport">
      <div class="project-track">
        {rest.map((p) => (
          <article class="card project-card project-open" role="button" tabindex="0" data-project={projJson(p)}>
            <img class="project-img" src={p.image} alt={p.title} draggable="false" width="320" height="160" loading="lazy" />
            <h3>{p.title}</h3>
            <p class="project-desc">{p.description}</p>
            <ul class="tags">
              {p.tags.map((t) => <li>{t}</li>)}
            </ul>
            <div class="project-links">
              {p.liveUrl && (
                <a class="btn btn-primary" href={p.liveUrl} target="_blank" rel="noreferrer">Live</a>
              )}
              <button type="button" class="btn btn-outline repo-open" data-repo={p.repoUrl} data-title={p.title}>Code</button>
            </div>
          </article>
        ))}
      </div>
    </div>
    <button type="button" class="carousel-btn next" aria-label="Next projects">&#8250;</button>
  </div>

  <Coursework />
</section>

<style is:global>
  .project-open { cursor: pointer; }
  .project-open:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  .project-carousel { position: relative; }
  .project-track { touch-action: pan-y; user-select: none; }

  /* Featured projects — full-width alternating image/text rows */
  .featured-rows { display: flex; flex-direction: column; gap: 4rem; margin-bottom: 5rem; }
  .featured-row { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center; }
  .featured-row:nth-child(even) .featured-media { order: 2; }
  .featured-media {
    position: relative; cursor: pointer;
    border: 1px solid var(--hair); border-radius: var(--r-card);
    background: var(--bg); overflow: hidden;
    transition: border-color 150ms ease;
  }
  .featured-media:hover { border-color: var(--accent); }
  .featured-media:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  .featured-img { width: 100%; height: 300px; object-fit: contain; padding: 1.5rem; display: block; }
  .featured-body { display: flex; flex-direction: column; align-items: flex-start; }
  .featured-body h3 { font-size: 1.5rem; margin: 0.6rem 0 0.5rem; }
  .featured-body .project-links { margin-top: 1.25rem; justify-content: flex-start; }
  .featured-meta {
    display: flex; flex-wrap: wrap; gap: 0.4rem 1.5rem;
    font-family: var(--font-mono); font-size: 0.72rem; margin: 0;
    text-transform: uppercase; letter-spacing: 0.03em;
  }
  .featured-meta div { display: flex; gap: 0.4rem; }
  .featured-meta dt { color: var(--muted); margin: 0; }
  .featured-meta dd { color: var(--text); margin: 0; }
  @media (max-width: 640px) {
    .featured-rows { gap: 2.5rem; margin-bottom: 3rem; }
    .featured-row { grid-template-columns: 1fr; gap: 1.25rem; }
    .featured-row:nth-child(even) .featured-media { order: 0; }
    .featured-img { height: 200px; }
  }
  .featured-badge {
    position: absolute; top: 0.75rem; right: 0.75rem; z-index: 2;
    padding: 0.2rem 0.5rem; border-radius: var(--r-tag);
    background: var(--accent); color: #fff; font-family: var(--font-mono); font-size: 0.68rem;
  }
  .carousel-btn {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 5;
    width: 40px; height: 40px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: var(--surface); color: var(--text); border: 1px solid var(--hair);
    font-size: 1.5rem; line-height: 1; cursor: pointer;
    transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease;
  }
  .carousel-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
  .carousel-btn.prev { left: -8px; }
  .carousel-btn.next { right: -8px; }
  @media (max-width: 640px) {
    .carousel-btn.prev { left: 0; }
    .carousel-btn.next { right: 0; }
  }
</style>

<script>
  function initCarousels() {
  document.querySelectorAll('.project-carousel').forEach((wrap) => {
    if (wrap.dataset.carouselInit) return; // already wired on this page
    const track = wrap.querySelector('.project-track');
    if (!track || track.children.length === 0) return;
    wrap.dataset.carouselInit = '1';
    const EASE = 0.2;      // arrow glide stiffness
    const FRICTION = 0.86; // drag-release momentum decay (lower = stops sooner)
    const MAX_V = 16;      // speed cap (px/frame) for fling + wheel
    const WHEEL_FACTOR = 0.5; // trackpad/wheel sensitivity
    let pos = 0;           // current translateX (px)
    let target = 0;        // arrow glide goal
    let vel = 0;           // momentum velocity (px/frame)
    let mode = 'idle';     // 'glide' (arrows) | 'inertia' (drag release)
    let raf = null;
    let dragging = false;
    let startX = 0, startPos = 0, moved = 0, lastX = 0;

    const step = () => {
      const card = track.querySelector('.project-card');
      const gap = parseFloat(getComputedStyle(track).columnGap || '24') || 24;
      return card.getBoundingClientRect().width + gap;
    };
    const setX = (x) => { track.style.transform = `translateX(${x}px)`; };
    const clamp = (v, m) => Math.max(-m, Math.min(m, v));
    const viewport = wrap.querySelector('.project-viewport');
    const cardW = () => track.querySelector('.project-card').getBoundingClientRect().width;
    // center the focused card in the viewport (neighbors peek on both sides)
    const recenter = () => { pos = (viewport.clientWidth - cardW()) / 2; rebalance(); setX(pos); };

    // Recycle cards so pos stays within (-step, 0]; shifting pos AND target together
    // keeps pixels + remaining distance intact -> seamless infinite loop, no snapping.
    const rebalance = () => {
      const s = step();
      let g = 0;
      while (pos <= -s && g++ < 400) { track.appendChild(track.firstElementChild); pos += s; target += s; }
      while (pos > 0 && g++ < 400) { track.insertBefore(track.lastElementChild, track.firstElementChild); pos -= s; target -= s; }
    };

    const tick = () => {
      if (mode === 'glide') {
        pos += (target - pos) * EASE;
        if (Math.abs(target - pos) < 0.5) { pos = target; mode = 'idle'; }
      } else if (mode === 'inertia') {
        pos += vel;
        vel *= FRICTION;
        if (Math.abs(vel) < 0.15) { vel = 0; mode = 'idle'; }
      }
      rebalance();
      setX(pos);
      raf = mode === 'idle' ? null : requestAnimationFrame(tick);
    };
    const run = () => { if (!raf) raf = requestAnimationFrame(tick); };

    // --- Arrows: glide one card per press; spam accumulates for a fast multi-card glide.
    const nudge = (dir) => {
      if (dragging) return;
      const base = mode === 'glide' ? target : pos;
      target = base + (dir > 0 ? -step() : step());
      mode = 'glide';
      run();
    };
    wrap.querySelector('.carousel-btn.next')?.addEventListener('click', () => nudge(1));
    wrap.querySelector('.carousel-btn.prev')?.addEventListener('click', () => nudge(-1));

    // center on load and keep centered on resize
    requestAnimationFrame(() => requestAnimationFrame(recenter));
    window.addEventListener('resize', recenter);

    // --- Auto-advance every 5s; pause on hover and when the tab is hidden.
    let timer = null;
    const startAuto = () => { if (!timer) timer = setInterval(() => nudge(1), 5000); };
    const stopAuto = () => { if (timer) { clearInterval(timer); timer = null; } };
    startAuto();
    wrap.addEventListener('mouseenter', stopAuto);
    wrap.addEventListener('mouseleave', startAuto);
    document.addEventListener('visibilitychange', () => (document.hidden ? stopAuto() : startAuto()));

    // Navigation is arrow-only — swipe/drag/wheel scrolling is intentionally disabled.
  });
  }
  initCarousels();
  document.addEventListener('astro:page-load', initCarousels);
</script>
