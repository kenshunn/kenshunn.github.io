---
import projects from '../data/projects.js';
---
<section id="projects" class="projects reveal">
  <p class="eyebrow">Browse my</p>
  <h2>Projects</h2>
  <div class="project-carousel">
    <button type="button" class="carousel-btn prev" aria-label="Previous projects">&#8249;</button>
    <div class="project-grid">
      {projects.map((p) => (
        <article class="card project-card">
          <img class="project-img" src={p.image} alt={p.title} />
          <h3>{p.title}</h3>
          <p class="project-desc">{p.description}</p>
          <ul class="tags">
            {p.tags.map((t) => <li>{t}</li>)}
          </ul>
          <div class="project-links">
            <a class="btn btn-outline" href={p.repoUrl} target="_blank" rel="noreferrer">Code</a>
            {p.liveUrl && (
              <a class="btn btn-primary" href={p.liveUrl} target="_blank" rel="noreferrer">Live</a>
            )}
          </div>
        </article>
      ))}
    </div>
    <button type="button" class="carousel-btn next" aria-label="Next projects">&#8250;</button>
  </div>
</section>

<style>
  .project-carousel { position: relative; }
  .carousel-btn {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 5;
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: var(--surface); color: var(--text);
    border: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
    font-size: 1.6rem; line-height: 1; cursor: pointer;
    transition: all 200ms ease;
  }
  .carousel-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
  .carousel-btn.prev { left: -8px; }
  .carousel-btn.next { right: -8px; }
  @media (max-width: 600px) {
    .carousel-btn.prev { left: 0; }
    .carousel-btn.next { right: 0; }
  }
</style>

<script>
  const wrap = document.querySelector('.project-carousel');
  const grid = wrap?.querySelector('.project-grid');

  if (wrap && grid && grid.children.length > 0) {
    // Clone the full set before and after the originals -> [clones][originals][clones]
    // so scrolling can wrap seamlessly in both directions (cylinder loop).
    const originals = Array.from(grid.children);
    const clone = (n) => {
      const c = n.cloneNode(true);
      c.setAttribute('aria-hidden', 'true');
      c.classList.add('clone');
      return c;
    };
    const head = document.createDocumentFragment();
    const tail = document.createDocumentFragment();
    originals.forEach((n) => head.appendChild(clone(n)));
    originals.forEach((n) => tail.appendChild(clone(n)));
    grid.appendChild(tail);
    grid.insertBefore(head, grid.firstChild);

    const n = originals.length;
    // Width of one set, measured from element offsets so grid padding doesn't skew it.
    const block = () => grid.children[n].offsetLeft - grid.children[0].offsetLeft;
    const step = () => {
      const gap = parseFloat(getComputedStyle(grid).columnGap || '24') || 24;
      return grid.querySelector('.project-card').getBoundingClientRect().width + gap;
    };

    // Start on the real (middle) set.
    requestAnimationFrame(() =>
      requestAnimationFrame(() => { grid.scrollLeft = block(); })
    );

    // After scrolling settles, jump by one set if we've drifted into a clone set.
    const normalize = () => {
      const b = block();
      if (b <= 0) return;
      if (grid.scrollLeft >= b * 2) grid.scrollLeft -= b;
      else if (grid.scrollLeft < b) grid.scrollLeft += b;
    };
    let t;
    grid.addEventListener('scroll', () => {
      clearTimeout(t);
      t = setTimeout(normalize, 120);
    });

    wrap.querySelector('.carousel-btn.prev')?.addEventListener('click', () =>
      grid.scrollBy({ left: -step(), behavior: 'smooth' })
    );
    wrap.querySelector('.carousel-btn.next')?.addEventListener('click', () =>
      grid.scrollBy({ left: step(), behavior: 'smooth' })
    );
  }
</script>
