---
const { title, blurb, tags = [], repoUrl } = Astro.props;
---
<article class="pcard">
  <h3>{title}</h3>
  <p>{blurb}</p>
  <div class="tag-row">
    {tags.map((t) => <span class="tag">{t}</span>)}
  </div>
  <a class="pcard-link" href={repoUrl} target="_blank" rel="noopener">Code ↗</a>
</article>
