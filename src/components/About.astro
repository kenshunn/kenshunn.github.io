---
import certifications from '../data/certifications.js';
const featured = certifications.filter((c) => c.featured);
const rest = certifications.filter((c) => !c.featured);

const education = [
  { school: 'Mapúa Malayan Colleges Laguna', degree: 'BS Information Technology', period: '2022 – Present', note: "Dean's Lister", logo: '/images/mapua.png' },
  { school: 'Far Eastern University Alabang', degree: 'STEM — Information Technology', period: '2020 – 2022', note: 'Graduated with Honors', logo: 'https://upload.wikimedia.org/wikipedia/en/thumb/d/d7/Far_Easter_University_Logo.svg/250px-Far_Easter_University_Logo.svg.png' },
];
---
<section id="about" class="about reveal">
  <p class="eyebrow">Get to know more</p>
  <h2>About Me</h2>

  <p class="bio">
    I'm Ken Aaron De Martin, an Information Technology student with a foundation
    in both network infrastructure and software development. Certified in CCNA
    and CompTIA Tech+, with hands-on experience in RHEL, TCP/IP, and end-to-end
    application logic. I work across Python, C++, C#, and JavaScript to build
    network-level security and real-time backend systems — aiming for a Junior
    Network Administrator or Junior Software Developer role building secure,
    scalable IT solutions.
  </p>

  <p class="eyebrow">Where I studied</p>
  <h2>Education</h2>
  <div class="edu-grid">
    {education.map((e) => (
      <div class="card edu-card">
        <img class="edu-logo" src={e.logo} alt={`${e.school} logo`} />
        <div>
          <h4>{e.school}</h4>
          <p class="edu-degree">{e.degree}</p>
          <p class="edu-meta">{e.period} · {e.note}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="projects-head">
    <div>
      <p class="eyebrow">What I've earned</p>
      <h2>Certifications</h2>
    </div>
    <button type="button" class="projects-grid-toggle" id="certs-grid-toggle" aria-label="View all certifications">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
        <rect x="3" y="3" width="8" height="8" rx="1.5"></rect>
        <rect x="13" y="3" width="8" height="8" rx="1.5"></rect>
        <rect x="3" y="13" width="8" height="8" rx="1.5"></rect>
        <rect x="13" y="13" width="8" height="8" rx="1.5"></rect>
      </svg>
    </button>
  </div>

  {featured.length > 0 && (
    <div class="featured-row">
      {featured.map((c) => (
        <article class="card featured-project">
          <span class="featured-badge">★ Featured</span>
          <img class="featured-img" src={c.logo} alt={`${c.issuer} logo`} draggable="false" />
          <div class="featured-body">
            <span class="cert-issuer">{c.issuer}</span>
            <h3>{c.name}</h3>
            <div class="project-links">
              <a class="btn btn-outline" href={c.url} target="_blank" rel="noreferrer">View credential</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  )}

  <div class="project-carousel">
    <button type="button" class="carousel-btn prev" aria-label="Previous certifications">&#8249;</button>
    <div class="project-viewport">
      <div class="project-track">
        {rest.map((c) => (
          <article class="card project-card cert-card">
            <img class="cert-logo" src={c.logo} alt={`${c.issuer} logo`} />
            <span class="cert-issuer">{c.issuer}</span>
            <h4>{c.name}</h4>
            <div class="project-links">
              <a class="btn btn-outline" href={c.url} target="_blank" rel="noreferrer">View credential</a>
            </div>
          </article>
        ))}
      </div>
    </div>
    <button type="button" class="carousel-btn next" aria-label="Next certifications">&#8250;</button>
  </div>
</section>

<style is:global>
  .cert-title { font-size: 1.4rem; margin-bottom: 1.25rem; }
  .edu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 2.5rem; }
  .edu-card { display: flex; gap: 1rem; align-items: center; }
  .edu-logo { width: auto; max-width: 110px; height: 56px; object-fit: contain; flex: none; }
  .edu-card h4 { font-size: 1.05rem; }
  .edu-degree { margin: 0.2rem 0 0; }
  .edu-meta { color: var(--muted); font-size: 0.85rem; margin-top: 0.25rem; }
  @media (max-width: 600px) { .edu-grid { grid-template-columns: 1fr; } }
  .cert-card { position: relative; flex-basis: 280px; }
  .cert-logo { width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.75rem; }
  .cert-issuer { color: var(--muted); font-size: 0.8rem; letter-spacing: 0.03em; text-transform: uppercase; }
  .cert-card h4 { font-size: 1.05rem; margin: 0.35rem 0 0; }
  @media (max-width: 600px) { .cert-card { flex-basis: 80vw; } }
</style>
