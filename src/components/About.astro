---
import certifications from '../data/certifications.js';
import seminars from '../data/seminars.js';
const primary = certifications.filter((c) => c.issuer !== 'Google Cloud');
const GC_PROFILE = 'https://www.skills.google/public_profiles/c6214554-2530-4cdb-a3da-8cb58d22236c';

const education = [
  { school: 'Mapúa Malayan Colleges Laguna', degree: 'BS Information Technology', period: '2022 – Present', note: "Dean's Lister", logo: '/images/mcl.webp' },
  { school: 'Far Eastern University Alabang', degree: 'STEM — Information Technology', period: '2020 – 2022', note: 'Graduated with Honors', logo: '/images/feu.webp' },
];
---
<section id="about" class="about reveal">
  <p class="eyebrow">Get to know more</p>
  <h2>About Me</h2>

  <p class="bio">
    I'm Ken Aaron De Martin — a software developer and IT student who builds
    full-stack web and mobile applications. I ship systems end to end: a
    voucher-management platform on CodeIgniter 4, an ASP.NET mental-health app,
    and a Kotlin attendance app with BLE proximity and multi-layer verification.
    Comfortable across
    PHP, C#, Kotlin, Python, and JavaScript — from database schema to UI — backed
    by a CompTIA Tech+ certification. Aiming for a Junior Software Developer role.
  </p>

  <p class="eyebrow">Where I studied</p>
  <h2>Education</h2>
  <div class="edu-grid">
    {education.map((e) => (
      <div class="card edu-card">
        <img class="edu-logo" src={e.logo} alt={`${e.school} logo`} width="80" height="80" loading="lazy" />
        <div>
          <h4>{e.school}</h4>
          <p class="edu-degree">{e.degree}</p>
          <p class="edu-meta">{e.period} · {e.note}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="projects-head">
    <div>
      <p class="eyebrow">What I've earned</p>
      <h2>Certifications</h2>
    </div>
    <button type="button" class="projects-grid-toggle" id="certs-grid-toggle" aria-label="View all certifications">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
        <rect x="3" y="3" width="8" height="8" rx="1.5"></rect>
        <rect x="13" y="3" width="8" height="8" rx="1.5"></rect>
        <rect x="3" y="13" width="8" height="8" rx="1.5"></rect>
        <rect x="13" y="13" width="8" height="8" rx="1.5"></rect>
      </svg>
    </button>
  </div>

  <div class="cert-grid">
    {primary.map((c) => (
      <article class={`card cert-card${c.featured ? ' cert-primary' : ''}`}>
        {c.featured && <span class="cert-star">★ Featured</span>}
        <img class="cert-logo" src={c.logo} alt={`${c.issuer} logo`} width="40" height="40" loading="lazy" />
        <span class="cert-issuer">{c.issuer}</span>
        <h4>{c.name}</h4>
        <div class="project-links">
          <a class="btn btn-outline" href={c.url} target="_blank" rel="noreferrer">View credential</a>
        </div>
      </article>
    ))}
    <article class="card cert-card gc-summary">
      <span class="cert-issuer">Google Cloud</span>
      <h4>8 skill badges</h4>
      <p class="gc-desc">Networking &amp; Security, Infrastructure, and Data / ML &amp; AI in Google Cloud.</p>
      <div class="project-links">
        <a class="btn btn-outline" href={GC_PROFILE} target="_blank" rel="noreferrer">View all</a>
      </div>
    </article>
  </div>

  {seminars.length > 0 && (
    <>
      <p class="eyebrow">Also attended</p>
      <h2>Seminars</h2>
      <div class="cert-grid">
        {seminars.map((s) => (
          <article class="card cert-card">
            <span class="cert-issuer">{s.org}</span>
            <h4>{s.title}</h4>
            {s.date && <p class="gc-desc">{s.date}</p>}
            {s.url && (
              <div class="project-links">
                <a class="btn btn-outline" href={s.url} target="_blank" rel="noreferrer">View certificate</a>
              </div>
            )}
          </article>
        ))}
      </div>
    </>
  )}
</section>

<style is:global>
  .cert-title { font-size: 1.4rem; margin-bottom: 1.25rem; }
  .edu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 2.5rem; }
  .edu-card { display: flex; gap: 1rem; align-items: center; }
  .edu-logo { width: 80px; height: 80px; object-fit: contain; flex: none; }
  .edu-card h4 { font-size: 1.05rem; }
  .edu-degree { margin: 0.2rem 0 0; }
  .edu-meta { color: var(--muted); font-size: 0.85rem; margin-top: 0.25rem; }
  .cert-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 1.25rem; }
  .cert-card { position: relative; display: flex; flex-direction: column; }
  .cert-primary { border-color: var(--accent); }
  .cert-star { position: absolute; top: 0.9rem; right: 0.9rem; font-family: var(--font-mono); font-size: 0.68rem; color: var(--accent); }
  .cert-logo { width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.75rem; }
  .cert-issuer { color: var(--muted); text-transform: uppercase; }
  .cert-card h4 { font-size: 1.05rem; margin: 0.35rem 0 0; }
  .cert-card .project-links { margin-top: auto; padding-top: 1rem; justify-content: flex-start; }
  .gc-desc { color: var(--muted); font-size: 0.9rem; margin-top: 0.4rem; }
  @media (max-width: 640px) { .edu-grid { grid-template-columns: 1fr; } }
</style>
