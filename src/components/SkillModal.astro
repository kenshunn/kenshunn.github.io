---
---
<div class="skill-modal" id="skill-modal" role="dialog" aria-modal="true" aria-label="Skill details" hidden>
  <div class="skill-modal-backdrop" data-skill-close></div>
  <div class="skill-modal-box">
    <div class="skill-modal-head">
      <h3 id="skill-modal-title">Skills</h3>
      <button type="button" class="skill-modal-close" aria-label="Close" data-skill-close>&times;</button>
    </div>
    <div class="skill-modal-body" id="skill-modal-body"></div>
  </div>
</div>

<style is:global>
  .skill-modal {
    position: fixed; inset: 0; z-index: 100;
    display: flex; align-items: center; justify-content: center; padding: 1.5rem;
  }
  .skill-modal[hidden] { display: none; }
  .skill-modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.65); backdrop-filter: blur(2px); }
  .skill-modal-box {
    position: relative; display: flex; flex-direction: column;
    width: min(580px, 100%); max-height: 82vh;
    background: var(--surface); color: var(--text);
    border: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
    border-radius: 1rem; overflow: hidden;
  }
  .skill-modal-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem 1.5rem; border-bottom: 1px solid color-mix(in srgb, var(--muted) 20%, transparent);
  }
  .skill-modal-close { background: none; border: none; color: var(--muted); font-size: 1.7rem; line-height: 1; cursor: pointer; }
  .skill-modal-close:hover { color: var(--text); }

  /* Seamless scroll: hide the scrollbar, fade the top/bottom edges. */
  .skill-modal-body {
    overflow-y: auto; padding: 1.4rem 1.5rem; display: flex; flex-direction: column; gap: 1.5rem;
    scrollbar-width: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 3.5%, #000 96.5%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0, #000 3.5%, #000 96.5%, transparent 100%);
  }
  .skill-modal-body::-webkit-scrollbar { display: none; }

  .skill-row { display: flex; flex-direction: column; gap: 0.35rem; }
  .skill-row-name { font-family: var(--font-mono); font-weight: 500; color: var(--accent); font-size: 0.95rem; }
  .skill-row p { color: var(--muted); line-height: 1.55; margin: 0; }
</style>

<script>
  const modal = document.getElementById('skill-modal');
  const titleEl = document.getElementById('skill-modal-title');
  const bodyEl = document.getElementById('skill-modal-body');
  const PERCENT = { Certified: 95, Proficient: 78, Familiar: 50 };

  const open = () => { modal?.removeAttribute('hidden'); document.body.style.overflow = 'hidden'; };
  const close = () => { modal?.setAttribute('hidden', ''); document.body.style.overflow = ''; };
  const esc = (s) =>
    (s || '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

  const rowHtml = (s) => `
      <div class="skill-row">
        <span class="skill-row-name">${esc(s.name)}</span>
        <p>${esc(s.detail || '')}</p>
      </div>`;

  const render = (title, items) => {
    if (titleEl) titleEl.textContent = title;
    if (bodyEl) { bodyEl.innerHTML = items.map(rowHtml).join(''); bodyEl.scrollTop = 0; }
    open();
  };

  document.querySelectorAll('.skill-group').forEach((card) => {
    const openGroup = () => {
      let items = [];
      try { items = JSON.parse(card.getAttribute('data-skills') || '[]'); } catch (e) { items = []; }
      render(card.getAttribute('data-group') || 'Skills', items);
    };
    card.addEventListener('click', openGroup);
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openGroup(); }
    });
  });

  document.querySelectorAll('.skill-tag').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      render(btn.getAttribute('data-name') || 'Skill', [{
        name: btn.getAttribute('data-name'),
        detail: btn.getAttribute('data-detail'),
      }]);
    });
  });

  modal?.querySelectorAll('[data-skill-close]').forEach((el) => el.addEventListener('click', close));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.hasAttribute('hidden')) close();
  });
</script>
