<style is:global>
  /* Monochrome affiliation row — matches type system, no brand colors */
  .affiliations { display: flex; align-items: center; gap: 1.1rem; margin-top: 1.5rem; }
  .affiliations a { display: inline-flex; color: var(--muted); transition: color 150ms ease, transform 150ms ease; }
  .affiliations a:hover { color: var(--accent); transform: translateY(-2px); }
  .affiliations svg { width: 22px; height: 22px; fill: currentColor; }
  .affiliations svg[fill='none'] { fill: none; }
  .aff-sep { width: 1px; height: 20px; background: var(--hair); }

  .tagline .tw {
    display: inline-block;
    white-space: nowrap;
  }
  .tagline .tw::after {
    content: ''; display: inline-block;
    width: 2px; height: 1em; margin-left: 2px;
    background: var(--accent); vertical-align: -0.15em;
    animation: tw-caret 0.8s step-end infinite;
  }
  @keyframes tw-caret { 50% { opacity: 0; } }
</style>

<script>
  function typeTagline() {
    const el = document.querySelector('.tagline .tw');
    if (!el) return;
    const full = el.getAttribute('data-text') || '';
    let i = 0;
    const type = () => {
      if (!document.body.contains(el)) return; // element swapped away
      el.textContent = full.slice(0, i);
      if (i++ <= full.length) setTimeout(type, 75);
    };
    type();
  }
  typeTagline();
  document.addEventListener('astro:page-load', typeTagline);
</script>
