---
import coursework from '../data/coursework.js';
---
<div class="coursework">
  <div class="projects-head">
    <div>
      <p class="eyebrow">Also</p>
      <h3 class="coursework-title">Coursework &amp; Exercises</h3>
    </div>
    <button type="button" class="projects-grid-toggle" id="coursework-grid-toggle" aria-label="View all coursework">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
        <rect x="3" y="3" width="8" height="8" rx="1.5"></rect>
        <rect x="13" y="3" width="8" height="8" rx="1.5"></rect>
        <rect x="3" y="13" width="8" height="8" rx="1.5"></rect>
        <rect x="13" y="13" width="8" height="8" rx="1.5"></rect>
      </svg>
    </button>
  </div>
  <div class="project-grid">
    {coursework.map((c) => (
      <article class="card project-card course-card">
        <h4>{c.title}</h4>
        <ul class="tags">
          {c.tags.map((t) => <li>{t}</li>)}
        </ul>
        <div class="project-links">
          <button type="button" class="btn btn-outline repo-open" data-repo={c.repoUrl} data-title={c.title}>Code</button>
        </div>
      </article>
    ))}
  </div>
</div>
