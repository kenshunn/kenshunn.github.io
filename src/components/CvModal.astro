---
---
<div class="cv-modal" id="cv-modal" role="dialog" aria-modal="true" aria-label="Curriculum Vitae" hidden>
  <div class="cv-modal-backdrop" data-cv-close></div>
  <div class="cv-modal-box">
    <div class="cv-modal-head">
      <h3>Curriculum Vitae</h3>
      <button type="button" class="cv-modal-close" aria-label="Close" data-cv-close>&times;</button>
    </div>
    <div class="cv-pages" id="cv-pages"><p class="cv-state">Loading preview…</p></div>
    <div class="cv-modal-foot">
      <a class="btn btn-primary" href="/KenAaronDeMartin-CV.pdf" download="KenAaronDeMartin-CV.pdf">Download CV</a>
      <a class="btn btn-outline" href="/KenAaronDeMartin-CV.pdf" target="_blank" rel="noreferrer">Open in new tab</a>
    </div>
  </div>
</div>

<style is:global>
  .cv-modal {
    position: fixed; inset: 0; z-index: 100;
    display: flex; align-items: center; justify-content: center;
    padding: 1.5rem;
  }
  .cv-modal[hidden] { display: none; }
  .cv-modal-backdrop {
    position: absolute; inset: 0;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(2px);
  }
  .cv-modal-box {
    position: relative;
    display: flex; flex-direction: column;
    width: min(1000px, 100%); height: min(92vh, 100%);
    background: var(--surface); color: var(--text);
    border-radius: 1rem; overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
  }
  .cv-modal-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--muted) 20%, transparent);
  }
  .cv-modal-head h3 { color: var(--text); }
  .cv-modal-close {
    background: none; border: none; color: var(--muted);
    font-size: 1.75rem; line-height: 1; cursor: pointer;
  }
  .cv-modal-close:hover { color: var(--text); }
  .cv-pages {
    flex: 1; overflow-y: auto; overflow-x: hidden; background: #525659;
    padding: 1.25rem; display: flex; flex-direction: column; align-items: center; gap: 1.25rem;
    scrollbar-width: none;
  }
  .cv-pages::-webkit-scrollbar { display: none; }
  .cv-pages canvas {
    display: block; width: 100%; max-width: 800px; height: auto;
    border-radius: 4px; box-shadow: 0 6px 24px rgba(0,0,0,0.4); background: #fff;
  }
  .cv-state { color: #e6edf3; padding: 2rem; }
  .cv-modal-foot {
    display: flex; justify-content: center; gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-top: 1px solid color-mix(in srgb, var(--muted) 20%, transparent);
  }
</style>

<script>
  if (!window.__cvModalBound) {
    window.__cvModalBound = true;
    const PDFJS = 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.7.76/build/pdf.min.mjs';
    const WORKER = 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.7.76/build/pdf.worker.min.mjs';

    async function renderCv() {
      const pages = document.getElementById('cv-pages');
      if (!pages || pages.querySelector('canvas')) return; // already rendered on this page
      try {
        const pdfjs = await import(/* @vite-ignore */ PDFJS);
        pdfjs.GlobalWorkerOptions.workerSrc = WORKER;
        const pdf = await pdfjs.getDocument('/KenAaronDeMartin-CV.pdf').promise;
        pages.innerHTML = '';
        for (let i = 1; i <= pdf.numPages; i++) {
          const page = await pdf.getPage(i);
          const viewport = page.getViewport({ scale: 2 });
          const canvas = document.createElement('canvas');
          canvas.width = viewport.width;
          canvas.height = viewport.height;
          pages.appendChild(canvas);
          await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
        }
      } catch (err) {
        pages.innerHTML = '<p class="cv-state">Preview unavailable — use the buttons below to view the CV.</p>';
      }
    }
    const close = () => { const m = document.getElementById('cv-modal'); if (m) { m.setAttribute('hidden', ''); document.body.style.overflow = ''; } };

    document.addEventListener('click', (e) => {
      if (e.target.closest('#cv-open')) { const m = document.getElementById('cv-modal'); if (m) { m.removeAttribute('hidden'); document.body.style.overflow = 'hidden'; renderCv(); } return; }
      if (e.target.closest('#cv-modal [data-cv-close], #cv-modal .cv-modal-backdrop')) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { const m = document.getElementById('cv-modal'); if (m && !m.hasAttribute('hidden')) close(); }
    });
  }
</script>
