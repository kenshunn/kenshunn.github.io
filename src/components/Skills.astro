---
import skills from '../data/skills.js';

// shields needs '-' doubled; everything else (#, /, +, spaces) via encodeURIComponent.
const enc = (s) => encodeURIComponent(s).replace(/-/g, '--');
const badgeUrl = (s) => {
  let url = `https://img.shields.io/badge/${enc(s.name)}-${enc(s.level || ' ')}-1f2937?style=for-the-badge&labelColor=${s.color || '555555'}`;
  if (s.logo) url += `&logo=${s.logo}&logoColor=${s.logoColor || 'white'}`;
  return url;
};
---
<section id="skills" class="skills reveal">
  <p class="eyebrow">Explore my</p>
  <h2>Skills</h2>
  <div class="skills-groups">
    {skills.map((group) => (
      <div class="card">
        <h3>{group.group}</h3>
        <div class="skill-list">
          {group.items.map((s) => (
            <img class="skill-badge" src={badgeUrl(s)} alt={s.name} height="30" loading="lazy" />
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
