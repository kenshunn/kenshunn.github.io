---
import skills from '../data/skills.js';

const badgeUrl = (s) => {
  const label = s.name.replace(/-/g, '--').replace(/ /g, '%20');
  let url = `https://img.shields.io/badge/${label}-${s.color || '555555'}?style=for-the-badge`;
  if (s.logo) url += `&logo=${s.logo}&logoColor=${s.logoColor || 'white'}`;
  return url;
};
---
<section id="skills" class="skills reveal">
  <p class="eyebrow">Explore my</p>
  <h2>Skills</h2>
  <div class="skills-groups">
    {skills.map((group) => (
      <div class="card">
        <h3>{group.group}</h3>
        <div class="skill-list">
          {group.items.map((s) => (
            <img class="skill-badge" src={badgeUrl(s)} alt={s.name} height="30" loading="lazy" />
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
