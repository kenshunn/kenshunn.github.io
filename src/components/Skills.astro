---
import skills from '../data/skills.js';
const groupData = (g) => JSON.stringify(g.items.map((s) => ({ name: s.name, detail: s.detail })));
---
<section id="skills" class="skills reveal screen">
  <p class="eyebrow">Explore my</p>
  <h2>Skills</h2>
  <div class="skills-groups">
    {skills.map((group) => (
      <div class="card skill-group" role="button" tabindex="0" data-group={group.group} data-skills={groupData(group)}>
        <div class="skill-group-head">
          <h3>{group.group}</h3>
          <span class="skill-group-hint">View all →</span>
        </div>
        <div class="skill-list">
          {group.items.map((s) => (
            <button type="button" class="skill-tag" data-name={s.name} data-detail={s.detail}>{s.name}</button>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
