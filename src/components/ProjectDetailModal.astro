---
---
<div class="pd-modal" id="project-detail-modal" role="dialog" aria-modal="true" aria-label="Project details" hidden>
  <div class="pd-backdrop" data-pd-close></div>
  <div class="pd-box">
    <div class="pd-head">
      <h3 id="pd-title">Project</h3>
      <button type="button" class="pd-close" aria-label="Close" data-pd-close>&times;</button>
    </div>
    <div class="pd-body" id="pd-body"></div>
    <div class="pd-foot" id="pd-foot"></div>
  </div>
</div>

<style is:global>
  .pd-modal { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; padding: 1.5rem; }
  .pd-modal[hidden] { display: none; }
  .pd-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.65); backdrop-filter: blur(2px); }
  .pd-box {
    position: relative; display: flex; flex-direction: column;
    width: min(760px, 100%); max-height: 88vh;
    background: var(--surface); color: var(--text);
    border: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
    border-radius: 1rem; overflow: hidden;
  }
  .pd-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem 1.5rem; border-bottom: 1px solid color-mix(in srgb, var(--muted) 20%, transparent);
  }
  .pd-close { background: none; border: none; color: var(--muted); font-size: 1.7rem; line-height: 1; cursor: pointer; }
  .pd-close:hover { color: var(--text); }
  .pd-body {
    overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.1rem;
    scrollbar-width: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 2.5%, #000 97.5%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0, #000 2.5%, #000 97.5%, transparent 100%);
  }
  .pd-body::-webkit-scrollbar { display: none; }
  .pd-hero { width: 100%; max-height: 260px; object-fit: contain; padding: 1rem; border-radius: 0.75rem; background: #0d1117; }
  .pd-body .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; list-style: none; }
  .pd-body .tags li { font-size: 0.8rem; padding: 0.2rem 0.6rem; border-radius: 1rem; background: color-mix(in srgb, var(--accent) 20%, transparent); color: var(--accent); }
  .pd-desc { color: var(--muted); line-height: 1.65; }
  .pd-shot { width: 100%; border-radius: 0.6rem; border: 1px solid color-mix(in srgb, var(--muted) 22%, transparent); }
  .pd-empty { color: var(--muted); font-size: 0.9rem; font-style: italic; }
  .pd-foot { display: flex; gap: 0.75rem; justify-content: flex-end; padding: 1rem 1.5rem; border-top: 1px solid color-mix(in srgb, var(--muted) 20%, transparent); }
</style>

<script>
  const modal = document.getElementById('project-detail-modal');
  const titleEl = document.getElementById('pd-title');
  const bodyEl = document.getElementById('pd-body');
  const footEl = document.getElementById('pd-foot');
  const esc = (s) => (s || '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

  const open = () => { modal?.removeAttribute('hidden'); document.body.style.overflow = 'hidden'; };
  const close = () => { modal?.setAttribute('hidden', ''); document.body.style.overflow = ''; };

  const render = (p) => {
    if (titleEl) titleEl.textContent = p.title || 'Project';
    if (bodyEl) {
      const tags = (p.tags || []).map((t) => `<li>${esc(t)}</li>`).join('');
      const shots = (p.gallery || []).length
        ? p.gallery.map((src) => `<img class="pd-shot" src="${esc(src)}" alt="${esc(p.title)} screenshot" loading="lazy" />`).join('')
        : '<p class="pd-empty">Screenshots coming soon.</p>';
      bodyEl.innerHTML = `
        <img class="pd-hero" src="${esc(p.image)}" alt="${esc(p.title)}" />
        <ul class="tags">${tags}</ul>
        <p class="pd-desc">${esc(p.description)}</p>
        ${shots}`;
      bodyEl.scrollTop = 0;
    }
    if (footEl) {
      const live = p.liveUrl ? `<a class="btn btn-primary" href="${esc(p.liveUrl)}" target="_blank" rel="noreferrer">Live</a>` : '';
      const code = `<a class="btn btn-outline" href="${esc(p.repoUrl)}" target="_blank" rel="noreferrer">Code</a>`;
      footEl.innerHTML = live + code;
    }
    open();
  };

  document.querySelectorAll('.project-open').forEach((card) => {
    const go = (e) => {
      if (e.target.closest('button, a')) return; // let inner Code/Live buttons work
      let p = {};
      try { p = JSON.parse(card.getAttribute('data-project') || '{}'); } catch (err) { p = {}; }
      render(p);
    };
    card.addEventListener('click', go);
    card.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(e); } });
  });

  modal?.querySelectorAll('[data-pd-close]').forEach((el) => el.addEventListener('click', close));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.hasAttribute('hidden')) close();
  });
</script>
