---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import VineBackground from '../components/VineBackground.astro';
---

<Layout title="Garden — Ken Aaron De Martin">
  <Navbar />
  <VineBackground />
  <main class="garden-page">
    <p class="eyebrow">A quiet corner</p>
    <h1>The Garden</h1>
    <p class="garden-lede">
      A living canvas that grows with the theme — an ASCII garland and flower bed by day,
      a constellation and crystal garden by night. Move your cursor and watch it react.
    </p>
    <a class="btn btn-outline" href="/#top">← Back to portfolio</a>
  </main>
</Layout>

<style is:global>
  .garden-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 1rem;
    padding: 96px 24px;
  }
  .garden-page .garden-lede { max-width: 42ch; color: var(--muted); }
  .garden-page .btn { margin-top: 1rem; }
</style>
