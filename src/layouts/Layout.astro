---
import '../styles/global.css';
const { title = 'Ken Aaron De Martin — Portfolio' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500&family=Public+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme') || 'dark';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <noscript>
      <style>
        .reveal { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/reveal.js';
    </script>
  </body>
</html>
